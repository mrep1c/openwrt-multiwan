# Minimal MultiWAN QoS starter configuration.
# Add WAN interface sections and rules through LuCI or UCI before use.

config global 'global'
	option enabled '0'

config settings 'settings'
	option DOWNRATE '0'
	option UPRATE '0'
	option ROOT_QDISC 'cake'

config advanced 'advanced'
	option PRESERVE_CONFIG_FILES '1'
	option WASHDSCPUP '1'
	option WASHDSCPDOWN '1'
	option WASHDSCPLAN '1'
	option WASHDSCPDOWNDELIVERY '1'
	option BWMAXRATIO '20'
	option UDP_RATE_LIMIT_ENABLED '0'
	option TCP_UPGRADE_ENABLED '0'
	option TCP_DOWNPRIO_INITIAL_ENABLED '0'
	option TCP_DOWNPRIO_SUSTAINED_ENABLED '0'
	option MSS '536'
	option NFT_HOOK 'forward'
	option NFT_PRIORITY '0'
	option MAX_CONNECTIONS '0'
	option COMMON_LINK_PRESETS 'ethernet'
	option ACKRATE '0'
	option MULTICAST_POLICING '0'
	option MULTICAST_RATE '0'

config hfsc 'hfsc'
	option gameqdisc 'pfifo'
	option nongameqdisc 'fq_codel'
	option nongameqdiscoptions 'besteffort ack-filter'
	option MAXDEL '24'
	option PFIFOMIN '5'
	option PACKETSIZE '450'
	option netemdelayms '0'
	option netemjitterms '0'
	option netemdist 'normal'
	option pktlossp 'none'
	option netem_direction 'both'

config cake 'cake'
	option PRIORITY_QUEUE_INGRESS 'diffserv3'
	option PRIORITY_QUEUE_EGRESS 'diffserv3'
	option HOST_ISOLATION '1'
	option NAT_INGRESS '1'
	option NAT_EGRESS '1'
	option ACK_FILTER_EGRESS 'auto'
	option AUTORATE_INGRESS '0'

config custom_rules 'custom_rules'

config agent 'agent'
	option enabled '0'
	option api_key ''
	option timeout '300'
