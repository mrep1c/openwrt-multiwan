EXTRA_HELP="
        check_version              Check for updates
        update                     Update multiwan_qos
        auto_setup [network]       Automatically configure one OpenWrt WAN network (default: wan)
        auto_setup_noninteractive [gaming_ip] [network]
                                   Automatically configure one WAN network with no interaction
        validate_custom_rules      Validate custom rules
        health_check               Check if MultiWAN QoS is properly configured and running
        refresh <device>           Refresh qdiscs for a specific device without restarting
        check_deps                 Check required runtime packages
        install_deps               Install missing runtime packages with apk/opkg"

REQUIRED_PACKAGES="kmod-sched ip-full nftables kmod-veth tc-full kmod-netem kmod-sched-ctinfo kmod-ifb kmod-sched-cake kmod-sched-red kmod-sched-drr kmod-sched-flower luci-lib-jsonc lua jsonfilter uclient-fetch ethtool"

