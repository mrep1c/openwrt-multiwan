### Utility functions

is_package_script_context() {
    local cmdline

    [ -n "${APK_SCRIPT:-}" ] && return 0
    [ -r "/proc/$PPID/cmdline" ] || return 1
    cmdline="$(tr '\0' ' ' 2>/dev/null < "/proc/$PPID/cmdline")"
    case "$cmdline" in
        */lib/apk/db/scripts/*|*/usr/lib/opkg/info/*|*post-install*|*post-upgrade*)
            return 0
            ;;
    esac
    return 1
}

calculate_realtime_rate_default() {
    local rate="$1" dir="$2" realtime cap

    [ "$rate" -gt 0 ] 2>/dev/null || rate=1

    realtime=1500

    cap=$((rate * 25 / 100))
    [ "$cap" -lt 1 ] && cap=1
    [ "$realtime" -gt "$cap" ] && realtime=$cap

    echo "$realtime"
}

uci_tmp() {
    uci -c "$TMP_CFG_DIR" "$@"
}

commit_tmp_config() {
    uci_tmp commit multiwan-qos &&
    cp "$TMP_CFG_FILE" "$MULTIWAN_QOS_CFG_FILE"
    local rv=$?
    rm -rf "$TMP_CFG_DIR"
    [ $rv = 0 ] || error_out "Failed to save the new config."
    return $rv
}

# 1 - string
# 2 - path to file
write_str_to_file() {
    printf '%s\n' "$1" > "$2" || { error_out "Failed to write to file '$2'."; return 1; }
    :
}

# 0 - (optional) '-p'
# 1 - path
try_mkdir() {
    local IFS="$DEFAULT_IFS" p=
    [ "$1" = '-p' ] && { p='-p'; shift; }
    [ -d "$1" ] && return 0
    mkdir ${p} "$1" || { error_out "Failed to create directory '$1'."; return 1; }
    :
}

check_util() { command -v "$1" 1>/dev/null; }

run_with_timeout() {
    local seconds="$1"
    shift
    if command -v timeout >/dev/null 2>&1; then
        timeout "$seconds" "$@"
    else
        "$@"
    fi
}

mark_multiwan_qos_restarting() {
    : > "$MULTIWAN_QOS_RESTARTING_FILE"
}

clear_multiwan_qos_restarting() {
    rm -f "$MULTIWAN_QOS_RESTARTING_FILE"
}

cleanup_agent_runtime_files() {
    local lock_dir=/tmp/multiwan_qos_agent.lock wait_count=0

    while mw_lock_owner_alive "$lock_dir" && [ "$wait_count" -lt 10 ]; do
        sleep 1
        wait_count=$((wait_count + 1))
    done
    if mw_lock_owner_alive "$lock_dir"; then
        log_msg -warn "Agent request pid $MW_LOCK_OWNER_PID is still active; preserving its runtime files."
        return 1
    fi
    mw_lock_reclaim_stale "$lock_dir" 2>/dev/null
    rm -f /tmp/multiwan_qos_agent_rules.nft /tmp/multiwan_qos_agent_last_seen /tmp/multiwan_qos_agent_rate_limit /tmp/multiwan_qos_agent_state.json
}

error_out() { log_msg -err "${@}"; }

# prints each argument to a separate line
print_msg() {
    local _arg
    for _arg in "$@"
    do
        case "${_arg}" in
            '') printf '\n' ;; # print out empty lines
            *) printf '%s\n' "${_arg}"
        esac
    done
    :
}

# logs each argument separately and prints to a separate line
# optional arguments: '-err', '-warn' to set logged error level
log_msg() {
    local msgs_prefix='' _arg err_l=info msgs_dest

    local IFS="$DEFAULT_IFS"
    for _arg in "$@"
    do
        case "${_arg}" in
            "-err") err_l=err msgs_prefix="Error: " ;;
            "-warn") err_l=warn msgs_prefix="Warning: " ;;
            '') printf '\n' ;; # print out empty lines
            *)
                case "$err_l" in
                    err|warn) msgs_dest="/dev/stderr" ;;
                    *) msgs_dest="/dev/stdout"
                esac
                printf '%s\n' "${msgs_prefix}${_arg}" > "$msgs_dest"
                logger -t multiwan_qos -p user."$err_l" "${msgs_prefix}${_arg}"
                msgs_prefix=''
        esac
    done
    :
}

# check if var names are safe to use with eval
are_var_names_safe() {
    local var_name
    for var_name in "$@"; do
        case "$var_name" in *[!a-zA-Z_]*) error_out "Invalid var name '$var_name'."; return 1; esac
    done
    :
}

### Update-related functions

# 1 - component: <BACKEND|FRONTEND>
# return codes:
# 0 - OK
# 1 - general error
# 2 - missing files
# 3 - missing reg file
# 4 - non-matching md5sums
check_files_integrity() {
    local files_missing='' reg_missing='' reg_file file files file_types component="$1"

    eval "file_types=\"\${MULTIWAN_QOS_FILE_TYPES_${component}}\"
        reg_file=\"\${MULTIWAN_QOS_FILES_REG_PATH_${component}}\""

    [ -f "$reg_file" ] || reg_missing=1

    files="$(print_file_list "$component" ALL)" && [ -n "$files" ] ||
        { error_out "Failed to get file list for component '$component'."; return 1; }
    
    local IFS="$_NL_"
    for file in $files; do
        [ -z "$file" ] || [ -f "$file" ] && continue
        error_out "Missing file: '$file'."
        files_missing=1
    done

    IFS="$DEFAULT_IFS"
    [ -z "$files_missing" ] || return 2
    [ -z "$reg_missing" ] || return 3

    md5sum -c "$reg_file" &>/dev/null || return 4
    :
}

# 1 - component: BACKEND|FRONTEND
# 2 - types: 'ALL' (doesn't print executable files) or any combination (space-separated) of 'GEN', 'EXTRA', 'JS', 'EXEC'
print_file_list() {
    local me=print_file_list file_type files='' \
        component="$1" file_types="$2"

    [ -n "$1" ] && [ -n "$2" ] || { error_out "$me: missing args."; return 1; }

    case "$component" in
        BACKEND|FRONTEND) ;;
        *) error_out "$me: invalid component '$component'."; return 1
    esac

    if [ "$file_types" = ALL ]; then
        eval "file_types=\"\${MULTIWAN_QOS_FILE_TYPES_${component}}\""
    fi

    for file_type in ${file_types}; do
        case "$file_type" in
            GEN|EXTRA|JS|EXEC)
                eval "files=\"${files}\${MULTIWAN_QOS_${file_type}_FILES_${component}}${_NL_}\"" ;;
            *) error_out "$me: invalid type '$file_type'"; return 1
        esac
    done

    # remove extra newlines, leading and trailing whitespaces and tabs
    printf '%s\n' "$files" | sed "s/^\s*//;s/\s*$//;/^$/d"
    :
}

