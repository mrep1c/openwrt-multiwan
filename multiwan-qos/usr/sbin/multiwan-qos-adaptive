#!/bin/sh

. /lib/functions.sh
. /lib/multiwan-qos/process-lock.sh
. /lib/multiwan-qos/realtime.sh

STATE_ROOT=/var/run/multiwan-qos/adaptive
LOCK_DIR=/var/run/multiwan_qos-refresh.lock
RESTARTING=/tmp/multiwan_qos_restarting
AGENT_SESSION_FILE=/var/run/multiwan-qos/agent-session
SAMPLE_INTERVAL=1
IDLE_POLL_INTERVAL=5
SESSION_GRACE_MS=20000
IDLE_POLL_AFTER_MS="$SESSION_GRACE_MS"
DEMAND_WINDOW_SAMPLES=3
TARGET_RESERVE_KBIT=300
DROP_INCREASE_KBIT=150
BACKLOG_DRAIN_MS=200
DECREASE_CONFIRM_MS=5000
DECREASE_DROP_FREE_MS=10000
DECREASE_INTERVAL_MS=5000
DECREASE_REARM_MS=10000
DECREASE_BACKLOG_FREE_MS=5000
SLOW_DEMAND_WINDOW_MS=30000
SESSION_IDLE_MS="$SESSION_GRACE_MS"

log() { logger -t multiwan-qos-adaptive -- "$*"; }

read_number() {
    local value
    if [ -r "$1" ]; then
        IFS= read -r value < "$1"
    else
        value="$2"
    fi
    case "$value" in ''|*[!0-9]*) value="$2" ;; esac
    MW_ADAPTIVE_NUMBER="$value"
}

read_agent_session_id() {
    local key value session_id=""

    MW_ADAPTIVE_AGENT_SESSION_ID=""
    [ -r "$AGENT_SESSION_FILE" ] || return 0
    while IFS='=' read -r key value; do
        [ "$key" = session_id ] && { session_id="$value"; break; }
    done < "$AGENT_SESSION_FILE"
    [ "${#session_id}" -eq 32 ] 2>/dev/null || return 0
    case "$session_id" in *[!0-9a-f]*) return 0 ;; esac
    MW_ADAPTIVE_AGENT_SESSION_ID="$session_id"
}

read_monotonic_ms() {
    local uptime seconds fraction d1 d2 d3

    IFS=' ' read -r uptime _ < /proc/uptime || return 1
    seconds="${uptime%%.*}"
    fraction="${uptime#*.}"
    [ "$fraction" != "$uptime" ] || fraction=0
    case "$seconds:$fraction" in *[!0-9:]*) return 1 ;; esac

    fraction="${fraction}000"
    d1="${fraction%${fraction#?}}"
    fraction="${fraction#?}"
    d2="${fraction%${fraction#?}}"
    fraction="${fraction#?}"
    d3="${fraction%${fraction#?}}"
    MW_ADAPTIVE_LOOP_NOW_MS=$((seconds * 1000 + d1 * 100 + d2 * 10 + d3))
}

read_realtime_stats() {
    local dev="$1" output

    output="$(tc -s class show dev "$dev" classid 1:11 2>/dev/null)" || {
        MW_ADAPTIVE_STATS=""
        return 1
    }
    mw_realtime_parse_tc_class_stats "$output" || {
        MW_ADAPTIVE_STATS=""
        return 1
    }
    case "$MW_RT_STATS_BYTES:$MW_RT_STATS_DROPS:$MW_RT_STATS_BACKLOG_BYTES:$MW_RT_STATS_BACKLOG_PACKETS:$MW_ADAPTIVE_LOOP_NOW_MS" in
        *[!0-9:]*) MW_ADAPTIVE_STATS=""; return 1 ;;
    esac
    [ "$MW_ADAPTIVE_LOOP_NOW_MS" -gt 0 ] || return 1
    MW_ADAPTIVE_STATS="$MW_RT_STATS_BYTES $MW_RT_STATS_DROPS $MW_RT_STATS_BACKLOG_BYTES $MW_RT_STATS_BACKLOG_PACKETS $MW_ADAPTIVE_LOOP_NOW_MS"
}

record_tc_failure() {
    local count retry

    read_number "$state_dir/tc_failures" 0
    count=$((MW_ADAPTIVE_NUMBER + 1))
    case "$count" in
        1) retry=1 ;;
        2) retry=2 ;;
        3) retry=4 ;;
        *) retry=5 ;;
    esac
    tc_failures="$count"
    tc_retry_after="$retry"
    ADAPTIVE_TC_FAILURES="$count"
    ADAPTIVE_TC_RETRY="$retry"
    printf '%s\n' "$count" > "$state_dir/tc_failures"
    printf '%s\n' "$retry" > "$state_dir/tc_retry_after"
    case "$count" in
        1|5|12|24|36) log "ERROR: adaptive $direction tc update failed on $dev; retrying with bounded backoff" ;;
    esac
}

clear_tc_failure() {
    [ "${tc_failures:-0}" -eq 0 ] && [ "${tc_retry_after:-0}" -eq 0 ] && return 0
    tc_failures=0
    tc_retry_after=0
    ADAPTIVE_TC_FAILURES=0
    ADAPTIVE_TC_RETRY=0
    printf '0\n' > "$state_dir/tc_failures"
    printf '0\n' > "$state_dir/tc_retry_after"
}

change_class() {
    local dev="$1" rate="$2" shaper="$3" burst_base_rate="$4"

    mw_realtime_curve "$rate" "$shaper" "$burst_base_rate"
    tc class change dev "$dev" parent 1:1 classid 1:11 hfsc rt \
        m1 "${MW_RT_BURST_RATE}kbit" d "${MW_RT_BURST_DURATION}ms" m2 "${MW_RT_SCHEDULER_RATE}kbit"
}

apply_rate() {
    local dev="$1" rate="$2" shaper="$3" burst_base_rate="$4" rv

    mw_lock_acquire "$LOCK_DIR" || return 2
    change_class "$dev" "$rate" "$shaper" "$burst_base_rate"
    rv=$?
    mw_lock_release_for "$LOCK_DIR" "$MW_LOCK_TOKEN"
    return "$rv"
}

profile_params() {
    local rate="$1" mtu="$2" packet_size realtime_target_ms

    mw_realtime_resolve_freshness "$FRESHNESS_MODE" "$FRESHNESS_TARGET_MS" "$MAXDEL"
    realtime_target_ms="$MW_RT_FRESHNESS_MS"
    mw_realtime_resolve_packet_size "$PACKETSIZE" "$mtu"
    packet_size="$MW_RT_RESOLVED_PACKET_SIZE"
    mw_realtime_queue_budget "$rate" "$realtime_target_ms" "$mtu" "$packet_size" "$PFIFOMIN"
    case "${ADAPTIVE_LEAF_MODE:-$GAME_QDISC}" in
        bfifo) ADAPTIVE_PROFILE_LIMIT="$MW_RT_QUEUE_BYTES" ;;
        pfifo) ADAPTIVE_PROFILE_LIMIT="$MW_RT_PFIFO_LIMIT" ;;
        *) ADAPTIVE_PROFILE_LIMIT=0 ;;
    esac
}

write_status() {
    local state_dir="$1" direction="$2" dev="$3" current="$4" shaper="$5"
    local state="$6" peak="$7" desired="$8" backlog="$9" drop_delta="${10}"
    local priority_mode=adaptive scheduler_rate="$current"
    printf 'mode=adaptive priority=%s direction=%s device=%s scheduler_rate=%s recommended_rate=%s queue_budget_rate=%s profile_mode=%s profile_rate=%s profile_limit=%s profile_drop_streak=%s profile_state=%s session_source=%s session_state=%s session_grace=%ss session_pending=%s activity=%s activity_source=%s idle_rate=%skbit floor=%s start=%s ceiling=%s poll_interval=%ss idle_poll_interval=%ss poll_state=%s demand_window=%ss reserve=%skbit peak=%s desired=%s backlog=%s backlog_bytes=%s instant_demand=%skbit backlog_drain=%skbit idle_hold=%s idle_hold_remaining_ms=%s drop_delta=%s stats_last_ok_ms=%s stats_failures=%s stats_retry=%s tc_failures=%s tc_retry=%s state=%s\n' \
        "$priority_mode" "$direction" "$dev" "$scheduler_rate" "$desired" "${ADAPTIVE_PROFILE_RATE:-$MW_RT_START}" \
        "${ADAPTIVE_LEAF_MODE:-static}" "${ADAPTIVE_PROFILE_RATE:-$MW_RT_START}" "${ADAPTIVE_PROFILE_LIMIT:-0}" "${ADAPTIVE_PROFILE_DROP_STREAK:-0}" "${ADAPTIVE_PROFILE_STATE:-fixed}" \
        "${ADAPTIVE_SESSION_SOURCE:-none}" "${ADAPTIVE_SESSION_STATE:-idle}" "$((SESSION_GRACE_MS / 1000))" "${ADAPTIVE_SESSION_PENDING:-0}" \
        "${ADAPTIVE_ACTIVITY_STATE:-idle}" "${ADAPTIVE_ACTIVITY_SOURCE:-none}" "$MW_RT_START" \
        "$MW_RT_FLOOR" "$MW_RT_START" "$MW_RT_CEILING" "$SAMPLE_INTERVAL" "$IDLE_POLL_INTERVAL" "${ADAPTIVE_POLL_STATE:-active}" "$DEMAND_WINDOW_SAMPLES" \
        "$TARGET_RESERVE_KBIT" "$peak" "$desired" "$backlog" "${ADAPTIVE_BACKLOG_BYTES:-0}" \
        "${ADAPTIVE_INSTANT_DEMAND:-0}" "${ADAPTIVE_BACKLOG_DRAIN_KBIT:-0}" "${ADAPTIVE_IDLE_HOLD:-0}" "${ADAPTIVE_IDLE_HOLD_REMAINING_MS:-0}" "$drop_delta" \
        "${ADAPTIVE_STATS_LAST_OK:-0}" "${ADAPTIVE_STATS_FAILURES:-0}" "${ADAPTIVE_STATS_RETRY:-0}" \
        "${ADAPTIVE_TC_FAILURES:-0}" "${ADAPTIVE_TC_RETRY:-0}" "$state" \
        > "$state_dir/status"
}

reset_sample_state() {
    local state_dir="$1" bytes="$2" drops="$3" backlog_bytes="$4" now="$5" current="$6"

    printf '%s\n' "$bytes" > "$state_dir/bytes"
    printf '%s\n' "$drops" > "$state_dir/drops"
    printf '%s\n' "$backlog_bytes" > "$state_dir/backlog_bytes"
    printf '%s\n' "$now" > "$state_dir/sample_ms"
    printf '%s\n' "$now" > "$state_dir/window_ms"
    printf '0\n' > "$state_dir/peak"
    printf '0\n' > "$state_dir/peak_1"
    printf '0\n' > "$state_dir/peak_2"
    printf '0\n' > "$state_dir/rolling_peak"
    printf '%s\n' "$current" > "$state_dir/desired"
    printf '0\n' > "$state_dir/backlog_samples"
    printf '0\n' > "$state_dir/lower_since"
    printf '0\n' > "$state_dir/last_decrease"
    printf '0\n' > "$state_dir/last_increase"
    printf '0\n' > "$state_dir/idle_since"
    printf '0\n' > "$state_dir/last_activity_ms"
    printf '0\n' > "$state_dir/slow_rate"
    printf '0\n' > "$state_dir/last_drop"
    printf '0\n' > "$state_dir/backlog_free_since"
    printf '0\n' > "$state_dir/peak_3"
    printf '0\n' > "$state_dir/peak_4"
    printf '0\n' > "$state_dir/rollback_rate"
    printf '0\n' > "$state_dir/rollback_until"
    rm -f "$state_dir/agent_session_pending"
}

process_direction() {
    local dev="$1" line_rate="$2" shaper="$3" direction="$4"
    local key state_dir current saved_current rate_needs_write stats bytes drops backlog backlog_bytes now previous_bytes previous_drops previous_backlog_bytes previous_ms elapsed
    local monitor_pid force_start
    local delta_bytes delta_drops instant_demand backlog_drain window_ms peak peak_1 peak_2 peak_3 peak_4 current_peak rolling_peak recent_peak desired down_target window_complete
    local backlog_samples backlog_step backlog_free_since lower_since last_decrease last_increase idle_since idle_elapsed new_session slow_rate slow_weight last_drop rollback_rate rollback_until drop_step new state rv
    local mtu profile_rate
    local stats_last_ok stats_failures stats_retry_after tc_failures tc_retry_after tc_backoff startup_state
    local agent_session_id saved_agent_session_id agent_session_changed agent_session_pending next_sample_ms
    local last_activity_ms traffic_active session_active activity_source session_state

    [ -d "/sys/class/net/$dev" ] || return 0
    [ ! -e "$STATE_ROOT/.detached-$dev" ] || return 0
    key="${dev}-${direction}"
    case "$key" in
        *[!A-Za-z0-9_.:@-]*) log "ERROR: unsafe adaptive state key for device '$dev'"; return 0 ;;
    esac
    state_dir="$STATE_ROOT/$key"
    [ -d "$state_dir" ] || mkdir -p "$state_dir"
    now="$MW_ADAPTIVE_LOOP_NOW_MS"
    agent_session_id="$MW_ADAPTIVE_AGENT_SESSION_ID"
    ADAPTIVE_POLL_STATE=active

    if [ -r "$state_dir/next_sample_ms" ]; then
        read_number "$state_dir/next_sample_ms" 0
        next_sample_ms="$MW_ADAPTIVE_NUMBER"
        saved_agent_session_id=""
        [ ! -r "$state_dir/agent_session_id" ] || IFS= read -r saved_agent_session_id < "$state_dir/agent_session_id"
        if [ "$next_sample_ms" -gt "$now" ] &&
            { [ -z "$agent_session_id" ] || [ "$agent_session_id" = "$saved_agent_session_id" ]; }; then
            return 0
        fi
        rm -f "$state_dir/next_sample_ms"
    fi

    mw_realtime_adaptive_profile_range "$line_rate"
    case "$GAME_QDISC" in
        bfifo|pfifo)
            ADAPTIVE_LEAF_MODE="$GAME_QDISC"
            ADAPTIVE_PROFILE_RATE="$MW_RT_PROFILE_START"
            ;;
        *)
            ADAPTIVE_LEAF_MODE="$GAME_QDISC"
            ADAPTIVE_PROFILE_RATE="$MW_RT_START"
            ;;
    esac
    mtu=""
    [ ! -r "/sys/class/net/$dev/mtu" ] || IFS= read -r mtu < "/sys/class/net/$dev/mtu"
    case "$mtu" in ''|*[!0-9]*) mtu=1500 ;; esac
    ADAPTIVE_PROFILE_STATE=fixed
    ADAPTIVE_PROFILE_DROP_STREAK=0
    ADAPTIVE_SESSION_SOURCE=none
    ADAPTIVE_SESSION_STATE=idle
    ADAPTIVE_SESSION_PENDING=0
    ADAPTIVE_ACTIVITY_STATE=idle
    ADAPTIVE_ACTIVITY_SOURCE=none
    ADAPTIVE_BACKLOG_BYTES=0
    ADAPTIVE_INSTANT_DEMAND=0
    ADAPTIVE_BACKLOG_DRAIN_KBIT=0
    ADAPTIVE_IDLE_HOLD=0
    ADAPTIVE_IDLE_HOLD_REMAINING_MS=0

    read_number "$state_dir/monitor_pid" 0
    monitor_pid="$MW_ADAPTIVE_NUMBER"
    force_start=0
    [ "$monitor_pid" -eq "$$" ] || force_start=1

    mw_realtime_adaptive_range "$line_rate" "$ADAPTIVE_START_RATE" "$ADAPTIVE_CUSTOM_START_RATE"
    rate_needs_write=0
    if [ "$force_start" -eq 1 ]; then
        current="$MW_RT_START"
        rate_needs_write=1
    elif [ -r "$state_dir/rate" ]; then
        IFS= read -r saved_current < "$state_dir/rate"
        case "$saved_current" in
            ''|*[!0-9]*) current="$MW_RT_START"; rate_needs_write=1 ;;
            *) current="$saved_current" ;;
        esac
    else
        current="$MW_RT_START"
        rate_needs_write=1
    fi
    if [ "$current" -lt "$MW_RT_FLOOR" ]; then
        current="$MW_RT_FLOOR"
        rate_needs_write=1
    elif [ "$current" -gt "$MW_RT_CEILING" ]; then
        current="$MW_RT_CEILING"
        rate_needs_write=1
    fi
    [ "$rate_needs_write" -eq 0 ] || printf '%s\n' "$current" > "$state_dir/rate"

    profile_rate="$ADAPTIVE_PROFILE_RATE"
    ADAPTIVE_PROFILE_RATE="$profile_rate"
    profile_params "$profile_rate" "$mtu"

    read_number "$state_dir/stats_last_ok" 0
    stats_last_ok="$MW_ADAPTIVE_NUMBER"
    read_number "$state_dir/stats_failures" 0
    stats_failures="$MW_ADAPTIVE_NUMBER"
    read_number "$state_dir/stats_retry_after" 0
    stats_retry_after="$MW_ADAPTIVE_NUMBER"
    read_number "$state_dir/tc_failures" 0
    tc_failures="$MW_ADAPTIVE_NUMBER"
    read_number "$state_dir/tc_retry_after" 0
    tc_retry_after="$MW_ADAPTIVE_NUMBER"
    tc_backoff=0
    if [ "$tc_retry_after" -gt 0 ]; then
        tc_retry_after=$((tc_retry_after - 1))
        printf '%s\n' "$tc_retry_after" > "$state_dir/tc_retry_after"
        tc_backoff=1
    fi
    ADAPTIVE_STATS_LAST_OK="$stats_last_ok"
    ADAPTIVE_STATS_FAILURES="$stats_failures"
    ADAPTIVE_STATS_RETRY="$stats_retry_after"
    ADAPTIVE_TC_FAILURES="$tc_failures"
    ADAPTIVE_TC_RETRY="$tc_retry_after"

    if [ "$stats_retry_after" -gt 0 ]; then
        stats_retry_after=$((stats_retry_after - 1))
        printf '%s\n' "$stats_retry_after" > "$state_dir/stats_retry_after"
        ADAPTIVE_STATS_RETRY="$stats_retry_after"
        write_status "$state_dir" "$direction" "$dev" "$current" "$shaper" stats-unavailable 0 "$current" 0 0
        return 0
    fi

    if ! read_realtime_stats "$dev"; then
        stats_failures=$((stats_failures + 1))
        case "$stats_failures" in
            1) stats_retry_after=1 ;;
            2) stats_retry_after=2 ;;
            3) stats_retry_after=4 ;;
            *) stats_retry_after=5 ;;
        esac
        printf '%s\n' "$stats_failures" > "$state_dir/stats_failures"
        printf '%s\n' "$stats_retry_after" > "$state_dir/stats_retry_after"
        ADAPTIVE_STATS_FAILURES="$stats_failures"
        ADAPTIVE_STATS_RETRY="$stats_retry_after"
        case "$stats_failures" in
            1|5|12|24|36) log "ERROR: adaptive $direction statistics unavailable on $dev; retrying with bounded backoff" ;;
        esac
        write_status "$state_dir" "$direction" "$dev" "$current" "$shaper" stats-unavailable 0 "$current" 0 0
        return 0
    fi
    set -- $MW_ADAPTIVE_STATS
    bytes="$1"; drops="$2"; backlog_bytes="$3"; backlog="$4"; now="$5"
    ADAPTIVE_BACKLOG_BYTES="$backlog_bytes"
    stats_last_ok="$now"
    stats_failures=0
    stats_retry_after=0
    printf '%s\n' "$stats_last_ok" > "$state_dir/stats_last_ok"
    printf '0\n' > "$state_dir/stats_failures"
    printf '0\n' > "$state_dir/stats_retry_after"
    ADAPTIVE_STATS_LAST_OK="$stats_last_ok"
    ADAPTIVE_STATS_FAILURES=0
    ADAPTIVE_STATS_RETRY=0

    if [ "$tc_backoff" -eq 1 ]; then
        ADAPTIVE_TC_FAILURES="$tc_failures"
        ADAPTIVE_TC_RETRY="$tc_retry_after"
        write_status "$state_dir" "$direction" "$dev" "$current" "$shaper" tc-backoff 0 "$current" "$backlog" 0
        return 0
    fi

    if [ "$force_start" -eq 1 ]; then
        apply_rate "$dev" "$current" "$shaper" "$MW_RT_START"
        rv=$?
        if [ "$rv" -eq 2 ]; then
            record_tc_failure
            write_status "$state_dir" "$direction" "$dev" "$current" "$shaper" lock-busy 0 "$current" "$backlog" 0
            return 0
        elif [ "$rv" -ne 0 ]; then
            record_tc_failure
            printf '%s\n' "failed to initialize $dev at ${current}kbit" > "$state_dir/error"
            ADAPTIVE_TC_FAILURES="$tc_failures"
            ADAPTIVE_TC_RETRY="$tc_retry_after"
            write_status "$state_dir" "$direction" "$dev" "$current" "$shaper" degraded 0 "$current" "$backlog" 0
            return 0
        fi
        printf '%s\n' "$$" > "$state_dir/monitor_pid"
        printf '%s\n' "$current" > "$state_dir/rate"
        clear_tc_failure
        ADAPTIVE_TC_FAILURES=0
        ADAPTIVE_TC_RETRY=0
        rm -f "$state_dir/error"
        startup_state=initializing
        reset_sample_state "$state_dir" "$bytes" "$drops" "$backlog_bytes" "$now" "$current"
        [ -z "$agent_session_id" ] || printf '%s\n' "$agent_session_id" > "$state_dir/agent_session_id"
        ADAPTIVE_TC_FAILURES="$tc_failures"
        ADAPTIVE_TC_RETRY="$tc_retry_after"
        write_status "$state_dir" "$direction" "$dev" "$current" "$shaper" "$startup_state" 0 "$current" "$backlog" 0
        return 0
    fi

    read_number "$state_dir/bytes" 0
    previous_bytes="$MW_ADAPTIVE_NUMBER"
    read_number "$state_dir/drops" 0
    previous_drops="$MW_ADAPTIVE_NUMBER"
    read_number "$state_dir/backlog_bytes" "$backlog_bytes"
    previous_backlog_bytes="$MW_ADAPTIVE_NUMBER"
    read_number "$state_dir/sample_ms" 0
    previous_ms="$MW_ADAPTIVE_NUMBER"
    if [ "$previous_ms" -eq 0 ]; then
        reset_sample_state "$state_dir" "$bytes" "$drops" "$backlog_bytes" "$now" "$current"
        write_status "$state_dir" "$direction" "$dev" "$current" "$shaper" initializing 0 "$current" "$backlog" 0
        return 0
    fi
    if [ "$bytes" -lt "$previous_bytes" ] || [ "$drops" -lt "$previous_drops" ]; then
        apply_rate "$dev" "$MW_RT_START" "$shaper" "$MW_RT_START"
        rv=$?
        if [ "$rv" -eq 2 ]; then
            record_tc_failure
            write_status "$state_dir" "$direction" "$dev" "$current" "$shaper" counter-reset-lock-busy 0 "$MW_RT_START" "$backlog" 0
            return 0
        elif [ "$rv" -ne 0 ]; then
            printf '%s\n' "failed to restore $dev to ${MW_RT_START}kbit after qdisc counters reset" > "$state_dir/error"
            record_tc_failure
            write_status "$state_dir" "$direction" "$dev" "$current" "$shaper" counter-reset-degraded 0 "$MW_RT_START" "$backlog" 0
            return 0
        fi
        current="$MW_RT_START"
        printf '%s\n' "$current" > "$state_dir/rate"
        rm -f "$state_dir/error"
        clear_tc_failure
        reset_sample_state "$state_dir" "$bytes" "$drops" "$backlog_bytes" "$now" "$current"
        log "Resynchronized $direction realtime HFSC rate on $dev after qdisc counters reset"
        write_status "$state_dir" "$direction" "$dev" "$current" "$shaper" counter-reset 0 "$current" "$backlog" 0
        return 0
    fi

    elapsed=$((now - previous_ms))
    [ "$elapsed" -gt 0 ] || return 0
    delta_bytes=$((bytes - previous_bytes))
    delta_drops=$((drops - previous_drops))
    mw_realtime_adaptive_demand "$delta_bytes" "$elapsed" "$backlog_bytes" "$previous_backlog_bytes" "$BACKLOG_DRAIN_MS"
    instant_demand="$MW_RT_INSTANT_DEMAND"
    backlog_drain="$MW_RT_BACKLOG_DRAIN_RATE"
    ADAPTIVE_INSTANT_DEMAND="$instant_demand"
    ADAPTIVE_BACKLOG_DRAIN_KBIT="$backlog_drain"
    printf '%s\n' "$bytes" > "$state_dir/bytes"
    printf '%s\n' "$drops" > "$state_dir/drops"
    printf '%s\n' "$backlog_bytes" > "$state_dir/backlog_bytes"
    printf '%s\n' "$now" > "$state_dir/sample_ms"

    traffic_active=0
    if [ "$delta_bytes" -gt 0 ] || [ "$backlog" -gt 0 ] || [ "$backlog_bytes" -gt 0 ] || [ "$delta_drops" -gt 0 ]; then
        traffic_active=1
    fi

    read_number "$state_dir/slow_rate" 0
    slow_rate="$MW_ADAPTIVE_NUMBER"
    if [ "$traffic_active" -eq 1 ]; then
        if [ "$slow_rate" -le 0 ]; then
            slow_rate="$instant_demand"
        else
            slow_weight="$elapsed"
            [ "$slow_weight" -gt "$SLOW_DEMAND_WINDOW_MS" ] && slow_weight="$SLOW_DEMAND_WINDOW_MS"
            slow_rate=$(((slow_rate * (SLOW_DEMAND_WINDOW_MS - slow_weight) + instant_demand * slow_weight + (SLOW_DEMAND_WINDOW_MS / 2)) / SLOW_DEMAND_WINDOW_MS))
        fi
    fi

    read_number "$state_dir/last_drop" 0
    last_drop="$MW_ADAPTIVE_NUMBER"
    if [ "$delta_drops" -gt 0 ]; then
        last_drop="$now"
    elif [ "$last_drop" -eq 0 ]; then
        last_drop="$now"
    fi
    printf '%s\n' "$last_drop" > "$state_dir/last_drop"

    read_number "$state_dir/backlog_free_since" 0
    backlog_free_since="$MW_ADAPTIVE_NUMBER"
    if [ "$backlog" -gt 0 ] || [ "$backlog_bytes" -gt 0 ]; then
        backlog_free_since=0
    elif [ "$backlog_free_since" -eq 0 ]; then
        backlog_free_since="$now"
    fi
    printf '%s\n' "$backlog_free_since" > "$state_dir/backlog_free_since"

    saved_agent_session_id=""
    if [ -r "$state_dir/agent_session_id" ]; then
        IFS= read -r saved_agent_session_id < "$state_dir/agent_session_id"
    fi
    read_number "$state_dir/agent_session_pending" 0
    agent_session_pending="$MW_ADAPTIVE_NUMBER"
    ADAPTIVE_SESSION_PENDING="$agent_session_pending"
    agent_session_changed=0
    if [ -z "$agent_session_id" ]; then
        agent_session_pending=0
        ADAPTIVE_SESSION_PENDING=0
        rm -f "$state_dir/agent_session_pending"
    elif [ "$agent_session_id" != "$saved_agent_session_id" ]; then
        printf '%s\n' "$agent_session_id" > "$state_dir/agent_session_id"
        printf '1\n' > "$state_dir/agent_session_pending"
        agent_session_pending=1
        ADAPTIVE_SESSION_PENDING=1
    fi
    if [ "$traffic_active" -eq 1 ] && [ "$agent_session_pending" -eq 1 ]; then
        agent_session_changed=1
        agent_session_pending=0
        ADAPTIVE_SESSION_PENDING=0
        rm -f "$state_dir/agent_session_pending"
    fi

    read_number "$state_dir/idle_since" 0
    idle_since="$MW_ADAPTIVE_NUMBER"
    new_session=0
    if [ "$agent_session_changed" -eq 1 ]; then
        new_session=1
        ADAPTIVE_SESSION_SOURCE=agent-flow
    fi
    if [ "$traffic_active" -eq 1 ]; then
        if [ "$new_session" -eq 0 ] && [ "$idle_since" -gt 0 ] &&
            [ $((now - idle_since)) -ge "$SESSION_IDLE_MS" ]; then
            new_session=1
            ADAPTIVE_SESSION_SOURCE=idle
        fi
        idle_since=0
    elif [ "$idle_since" -eq 0 ]; then
        # A zero delta covers the interval since the previous sample, so use
        # that boundary rather than adding a one-sample delay to idle timers.
        idle_since="$previous_ms"
    fi
    printf '%s\n' "$idle_since" > "$state_dir/idle_since"
    idle_elapsed=0
    if [ "$traffic_active" -eq 0 ] && [ "$idle_since" -gt 0 ]; then
        idle_elapsed=$((now - idle_since))
        mw_realtime_adaptive_idle_state "$idle_elapsed" "$SESSION_GRACE_MS" "$current" "$MW_RT_START"
        ADAPTIVE_IDLE_HOLD="$MW_RT_IDLE_HOLD"
        ADAPTIVE_IDLE_HOLD_REMAINING_MS="$MW_RT_IDLE_REMAINING_MS"
    else
        ADAPTIVE_IDLE_HOLD=0
        ADAPTIVE_IDLE_HOLD_REMAINING_MS=0
    fi
    if [ "$idle_since" -gt 0 ] && [ $((now - idle_since)) -ge "$IDLE_POLL_AFTER_MS" ]; then
        next_sample_ms=$((now + IDLE_POLL_INTERVAL * 1000))
        printf '%s\n' "$next_sample_ms" > "$state_dir/next_sample_ms"
        ADAPTIVE_POLL_STATE=idle
    else
        [ ! -e "$state_dir/next_sample_ms" ] || rm -f "$state_dir/next_sample_ms"
        ADAPTIVE_POLL_STATE=active
    fi

    # Session continuity and current traffic are deliberately separate. During
    # grace, keep the last safe rate and freeze demand history until traffic
    # returns or the full idle interval expires.
    read_number "$state_dir/last_activity_ms" 0
    last_activity_ms="$MW_ADAPTIVE_NUMBER"
    if [ "$traffic_active" -eq 0 ] && [ "$last_activity_ms" -eq 0 ]; then
        ADAPTIVE_IDLE_HOLD=0
        ADAPTIVE_IDLE_HOLD_REMAINING_MS=0
    fi
    session_active=0
    activity_source=none
    session_state=idle
    if [ "$traffic_active" -eq 1 ]; then
        last_activity_ms="$now"
        session_active=1
        activity_source=traffic
        session_state=active
    elif [ "$last_activity_ms" -gt 0 ] &&
        [ $((now - last_activity_ms)) -lt "$SESSION_GRACE_MS" ]; then
        session_active=1
        session_state=grace
    fi
    printf '%s\n' "$last_activity_ms" > "$state_dir/last_activity_ms"
    if [ "$traffic_active" -eq 1 ]; then
        ADAPTIVE_ACTIVITY_STATE=active
        ADAPTIVE_ACTIVITY_SOURCE="$activity_source"
    else
        ADAPTIVE_ACTIVITY_STATE=idle
        ADAPTIVE_ACTIVITY_SOURCE=none
    fi
    ADAPTIVE_SESSION_STATE="$session_state"
    if [ -n "$agent_session_id" ]; then
        ADAPTIVE_SESSION_SOURCE=agent-flow
    elif [ "$session_active" -eq 1 ]; then
        ADAPTIVE_SESSION_SOURCE="$session_state"
    fi

    read_number "$state_dir/window_ms" "$now"
    window_ms="$MW_ADAPTIVE_NUMBER"
    read_number "$state_dir/peak" 0
    peak="$MW_ADAPTIVE_NUMBER"
    read_number "$state_dir/peak_1" 0
    peak_1="$MW_ADAPTIVE_NUMBER"
    read_number "$state_dir/peak_2" 0
    peak_2="$MW_ADAPTIVE_NUMBER"
    read_number "$state_dir/peak_3" 0
    peak_3="$MW_ADAPTIVE_NUMBER"
    read_number "$state_dir/peak_4" 0
    peak_4="$MW_ADAPTIVE_NUMBER"
    read_number "$state_dir/rolling_peak" 0
    rolling_peak="$MW_ADAPTIVE_NUMBER"
    read_number "$state_dir/desired" "$current"
    desired="$MW_ADAPTIVE_NUMBER"
    window_complete=0
    recent_peak="$rolling_peak"
    [ "$peak_3" -gt "$recent_peak" ] && recent_peak="$peak_3"
    [ "$peak_4" -gt "$recent_peak" ] && recent_peak="$peak_4"
    if [ "$traffic_active" -eq 1 ] && [ $((now - window_ms)) -ge 1000 ]; then
        current_peak="$peak"
        [ "$instant_demand" -gt "$current_peak" ] && current_peak="$instant_demand"
        rolling_peak="$current_peak"
        [ "$peak_1" -gt "$rolling_peak" ] && rolling_peak="$peak_1"
        [ "$peak_2" -gt "$rolling_peak" ] && rolling_peak="$peak_2"
        mw_realtime_adaptive_target "$rolling_peak" "$TARGET_RESERVE_KBIT" "$MW_RT_FLOOR" "$MW_RT_CEILING"
        desired="$MW_RT_ADAPTIVE_TARGET"
        recent_peak="$rolling_peak"
        [ "$peak_3" -gt "$recent_peak" ] && recent_peak="$peak_3"
        [ "$peak_4" -gt "$recent_peak" ] && recent_peak="$peak_4"
        peak_4="$peak_3"
        peak_3="$peak_2"
        peak_2="$peak_1"
        peak_1="$current_peak"
        peak=0
        window_ms="$now"
        window_complete=1
    elif [ "$traffic_active" -eq 1 ] && [ "$instant_demand" -gt "$peak" ]; then
        peak="$instant_demand"
    fi
    down_target="$slow_rate"
    [ "$recent_peak" -gt "$down_target" ] && down_target="$recent_peak"
    mw_realtime_adaptive_target "$down_target" "$TARGET_RESERVE_KBIT" "$MW_RT_FLOOR" "$MW_RT_CEILING"
    down_target="$MW_RT_ADAPTIVE_TARGET"

    if [ "$new_session" -eq 1 ]; then
        peak="$instant_demand"
        peak_1=0
        peak_2=0
        peak_3=0
        peak_4=0
        rolling_peak=0
        recent_peak="$instant_demand"
        slow_rate="$instant_demand"
        down_target="$MW_RT_START"
        desired="$MW_RT_START"
        window_ms="$now"
        window_complete=0
    fi
    if [ "$traffic_active" -eq 0 ]; then
        desired="${MW_RT_IDLE_TARGET:-$current}"
        down_target="$desired"
        if [ "$ADAPTIVE_IDLE_HOLD" -eq 0 ]; then
            desired="$MW_RT_START"
            down_target="$MW_RT_START"
            peak=0
            peak_1=0
            peak_2=0
            peak_3=0
            peak_4=0
            rolling_peak=0
            slow_rate=0
            window_ms="$now"
            window_complete=0
        fi
    fi

    printf '%s\n' "$slow_rate" > "$state_dir/slow_rate"
    printf '%s\n' "$window_ms" > "$state_dir/window_ms"
    printf '%s\n' "$peak" > "$state_dir/peak"
    printf '%s\n' "$peak_1" > "$state_dir/peak_1"
    printf '%s\n' "$peak_2" > "$state_dir/peak_2"
    printf '%s\n' "$peak_3" > "$state_dir/peak_3"
    printf '%s\n' "$peak_4" > "$state_dir/peak_4"
    printf '%s\n' "$rolling_peak" > "$state_dir/rolling_peak"
    printf '%s\n' "$desired" > "$state_dir/desired"

    read_number "$state_dir/backlog_samples" 0
    backlog_samples="$MW_ADAPTIVE_NUMBER"
    if [ "$backlog" -gt 0 ] || [ "$backlog_bytes" -gt 0 ]; then
        backlog_samples=$((backlog_samples + 1))
    else
        backlog_samples=0
    fi
    printf '%s\n' "$backlog_samples" > "$state_dir/backlog_samples"

    read_number "$state_dir/lower_since" 0
    lower_since="$MW_ADAPTIVE_NUMBER"
    read_number "$state_dir/last_decrease" 0
    last_decrease="$MW_ADAPTIVE_NUMBER"
    read_number "$state_dir/last_increase" 0
    last_increase="$MW_ADAPTIVE_NUMBER"
    read_number "$state_dir/rollback_rate" 0
    rollback_rate="$MW_ADAPTIVE_NUMBER"
    read_number "$state_dir/rollback_until" 0
    rollback_until="$MW_ADAPTIVE_NUMBER"
    if [ "$rollback_until" -gt 0 ] && [ "$now" -gt "$rollback_until" ]; then
        rollback_rate=0
        rollback_until=0
        printf '0\n' > "$state_dir/rollback_rate"
        printf '0\n' > "$state_dir/rollback_until"
    fi
    new="$current"
    state=tracking

    if [ "$new_session" -eq 1 ]; then
        new="$current"
        [ "$new" -lt "$MW_RT_START" ] && new="$MW_RT_START"
        if [ "$delta_drops" -gt 0 ]; then
            drop_step="$DROP_INCREASE_KBIT"
            [ "$delta_drops" -ge 10 ] && drop_step=200
            [ "$delta_drops" -ge 50 ] && drop_step=250
            [ $((current + drop_step)) -gt "$new" ] && new=$((current + drop_step))
            state=session-drop-increase
        elif [ "$backlog" -gt 0 ] || [ "$backlog_bytes" -gt 0 ]; then
            mw_realtime_adaptive_backlog_step "$backlog_drain"
            backlog_step="$MW_RT_BACKLOG_STEP"
            [ $((current + backlog_step)) -gt "$new" ] && new=$((current + backlog_step))
            [ "$desired" -gt "$new" ] && new="$desired"
            state=session-backlog-increase
        else
            state=session-start
        fi
        [ "$new" -gt "$MW_RT_CEILING" ] && new="$MW_RT_CEILING"
        lower_since=0
        last_increase="$now"
        rollback_rate=0
        rollback_until=0
        printf '0\n' > "$state_dir/rollback_rate"
        printf '0\n' > "$state_dir/rollback_until"
    elif [ "$traffic_active" -eq 0 ]; then
        lower_since=0
        if [ "$ADAPTIVE_IDLE_HOLD" -eq 1 ]; then
            new="${MW_RT_IDLE_TARGET:-$current}"
            state=idle-hold
        else
            new="${MW_RT_IDLE_TARGET:-$MW_RT_START}"
            [ "$new" -gt "$current" ] && last_increase="$now"
            rollback_rate=0
            rollback_until=0
            printf '0\n' > "$state_dir/rollback_rate"
            printf '0\n' > "$state_dir/rollback_until"
            if [ "$new" -ne "$current" ]; then
                state=idle-baseline
            else
                state=idle
            fi
        fi
    elif [ "$rollback_rate" -gt "$current" ] && [ "$rollback_until" -ge "$now" ] &&
        { [ "$delta_drops" -gt 0 ] || [ "$backlog" -gt 0 ] || [ "$backlog_bytes" -gt 0 ]; }; then
        new="$rollback_rate"
        [ "$desired" -gt "$new" ] && new="$desired"
        [ "$new" -gt "$MW_RT_CEILING" ] && new="$MW_RT_CEILING"
        lower_since=0
        last_increase="$now"
        state=decrease-rollback
    elif [ "$delta_drops" -gt 0 ]; then
        drop_step="$DROP_INCREASE_KBIT"
        [ "$delta_drops" -ge 10 ] && drop_step=200
        [ "$delta_drops" -ge 50 ] && drop_step=250
        new=$((current + drop_step))
        [ "$desired" -gt "$new" ] && new="$desired"
        [ "$new" -gt "$MW_RT_CEILING" ] && new="$MW_RT_CEILING"
        lower_since=0
        last_increase="$now"
        state=drop-increase
    elif [ "$backlog_samples" -ge 2 ] && [ $((now - last_increase)) -ge 1000 ]; then
        mw_realtime_adaptive_backlog_step "$backlog_drain"
        backlog_step="$MW_RT_BACKLOG_STEP"
        new=$((current + backlog_step))
        [ "$desired" -gt "$new" ] && new="$desired"
        [ "$new" -gt "$MW_RT_CEILING" ] && new="$MW_RT_CEILING"
        lower_since=0
        last_increase="$now"
        state=backlog-increase
    elif [ "$window_complete" -eq 1 ] && [ "$desired" -ge $((current + 100)) ]; then
        new="$desired"
        lower_since=0
        last_increase="$now"
        state=demand-increase
    elif [ "$backlog" -gt 0 ] || [ "$backlog_bytes" -gt 0 ]; then
        lower_since=0
    elif [ "$window_complete" -eq 1 ] && [ "$down_target" -lt "$current" ]; then
        [ "$lower_since" -eq 0 ] && lower_since="$now"
        mw_realtime_adaptive_decrease_ready "$now" "$backlog_free_since" "$last_drop" "$last_increase" \
            "$lower_since" "$last_decrease" "$DECREASE_BACKLOG_FREE_MS" "$DECREASE_DROP_FREE_MS" \
            "$DECREASE_REARM_MS" "$DECREASE_CONFIRM_MS" "$DECREASE_INTERVAL_MS"
        if [ "$MW_RT_DECREASE_READY" -eq 1 ]; then
            new=$((current - 50))
            [ "$new" -lt "$down_target" ] && new="$down_target"
            [ "$new" -lt "$MW_RT_FLOOR" ] && new="$MW_RT_FLOOR"
            if [ "$new" -lt "$current" ]; then
                last_decrease="$now"
                state=demand-decrease
            fi
        fi
    elif [ "$window_complete" -eq 1 ]; then
        lower_since=0
    fi

    printf '%s\n' "$lower_since" > "$state_dir/lower_since"
    printf '%s\n' "$last_decrease" > "$state_dir/last_decrease"
    printf '%s\n' "$last_increase" > "$state_dir/last_increase"

    if [ "$new" -ne "$current" ]; then
        apply_rate "$dev" "$new" "$shaper" "$MW_RT_START"
        rv=$?
        if [ "$rv" -eq 2 ]; then
            state=lock-busy
            new="$current"
            record_tc_failure
        elif [ "$rv" -ne 0 ]; then
            printf '%s\n' "failed to change $dev from ${current}kbit to ${new}kbit" > "$state_dir/error"
            record_tc_failure
            state=degraded
            new="$current"
        else
            printf '%s\n' "$new" > "$state_dir/rate"
            rm -f "$state_dir/error"
            if [ "$state" = demand-decrease ]; then
                printf '%s\n' "$current" > "$state_dir/rollback_rate"
                printf '%s\n' $((now + 3000)) > "$state_dir/rollback_until"
            elif [ "$new" -gt "$current" ]; then
                printf '0\n' > "$state_dir/rollback_rate"
                printf '0\n' > "$state_dir/rollback_until"
            fi
            log "Adjusted $direction realtime HFSC rate on $dev: ${current}kbit -> ${new}kbit"
            clear_tc_failure
        fi
    fi

    ADAPTIVE_PROFILE_RATE="$profile_rate"
    profile_params "$profile_rate" "$mtu"
    ADAPTIVE_TC_FAILURES="$tc_failures"
    ADAPTIVE_TC_RETRY="$tc_retry_after"
    write_status "$state_dir" "$direction" "$dev" "$new" "$shaper" "$state" "$rolling_peak" "$desired" "$backlog" "$delta_drops"
}

process_interface() {
    local section="$1" enabled device qdisc upload download shaper ifb

    config_get_bool enabled "$section" enabled 1
    [ "$enabled" -eq 1 ] || return 0
    config_get device "$section" device
    config_get qdisc "$section" qdisc hfsc
    case "$qdisc" in hfsc|hybrid) ;; *) return 0 ;; esac
    config_get upload "$section" upload
    config_get download "$section" download

    shaper="$upload"; [ "$qdisc" = hybrid ] && shaper=$((upload * 98 / 100))
    process_direction "$device" "$upload" "$shaper" wan

    ifb="ifb-$device"
    shaper="$download"; [ "$qdisc" = hybrid ] && shaper=$((download * 98 / 100))
    process_direction "$ifb" "$download" "$shaper" lan
}

mkdir -p "$STATE_ROOT"
while [ -f "$RESTARTING" ]; do sleep 1; done

config_load multiwan-qos
config_get RATE_MODE hfsc realtime_rate_mode default
[ "$RATE_MODE" = adaptive ] || exit 0
config_get ADAPTIVE_START_RATE hfsc adaptive_start_rate 1000
case "$ADAPTIVE_START_RATE" in
    1000|1500) ;;
    custom)
        config_get ADAPTIVE_CUSTOM_START_RATE hfsc adaptive_custom_start_rate 1000
        case "$ADAPTIVE_CUSTOM_START_RATE" in
            ''|*[!0-9]*)
                log "ERROR: invalid adaptive_custom_start_rate '$ADAPTIVE_CUSTOM_START_RATE'; expected 300-2000 kbit/s"
                exit 1
                ;;
        esac
        if [ "$ADAPTIVE_CUSTOM_START_RATE" -lt 300 ] || [ "$ADAPTIVE_CUSTOM_START_RATE" -gt 2000 ]; then
            log "ERROR: invalid adaptive_custom_start_rate '$ADAPTIVE_CUSTOM_START_RATE'; expected 300-2000 kbit/s"
            exit 1
        fi
        ;;
    *) log "ERROR: unsupported adaptive_start_rate '$ADAPTIVE_START_RATE'; expected 1000, 1500, or custom"; exit 1 ;;
esac
: "${ADAPTIVE_CUSTOM_START_RATE:=1000}"
config_get TARGET_RESERVE_KBIT hfsc adaptive_demand_reserve 300
case "$TARGET_RESERVE_KBIT" in
    ''|*[!0-9]*)
        log "ERROR: invalid adaptive_demand_reserve '$TARGET_RESERVE_KBIT'; expected 0-2000 kbit/s"
        exit 1
        ;;
esac
if [ "$TARGET_RESERVE_KBIT" -gt 2000 ]; then
    log "ERROR: invalid adaptive_demand_reserve '$TARGET_RESERVE_KBIT'; expected 0-2000 kbit/s"
    exit 1
fi
config_get GAME_QDISC hfsc gameqdisc bfifo
config_get FRESHNESS_MODE hfsc freshness_mode auto
config_get FRESHNESS_TARGET_MS hfsc freshness_target_ms 18
config_get MAXDEL hfsc MAXDEL 24
config_get PFIFOMIN hfsc PFIFOMIN 5
config_get PACKETSIZE hfsc PACKETSIZE 450

while true; do
    [ -f "$RESTARTING" ] && exit 0
    if ! read_monotonic_ms; then
        log "ERROR: adaptive monitor could not read monotonic time"
        sleep "$SAMPLE_INTERVAL"
        continue
    fi
    read_agent_session_id
    config_foreach process_interface interface
    sleep "$SAMPLE_INTERVAL"
done

exit 0
