#!/bin/sh

. /lib/functions.sh
. /lib/multiwan-qos/process-lock.sh
. /lib/multiwan-qos/realtime.sh

STATE_ROOT=/var/run/multiwan-qos/adaptive
LOCK_DIR=/var/run/multiwan_qos-refresh.lock
RESTARTING=/tmp/multiwan_qos_restarting
SAMPLE_INTERVAL=1

log() { logger -t multiwan-qos-adaptive -- "$*"; }

read_number() {
    local value
    if [ -r "$1" ]; then
        IFS= read -r value < "$1"
    else
        value="$2"
    fi
    case "$value" in ''|*[!0-9]*) value="$2" ;; esac
    printf '%s' "$value"
}

read_realtime_stats() {
    local dev="$1" stats

    stats="$(tc -s class show dev "$dev" classid 1:11 2>/dev/null)" || return 1
    printf '%s\n' "$stats" | awk '
        BEGIN {
            if ((getline uptime < "/proc/uptime") > 0) {
                split(uptime, field, " ")
                now = int((field[1] * 1000) + 0.5)
            }
            close("/proc/uptime")
        }
        / Sent / && bytes == "" {
            bytes = $2
            for (i = 1; i <= NF; i++) {
                key = $i
                gsub(/[(),]/, "", key)
                if (key == "dropped") {
                    drops = $(i + 1)
                    gsub(/[(),]/, "", drops)
                }
            }
        }
        /backlog/ && backlog == "" {
            backlog = $3
            sub(/p$/, "", backlog)
        }
        END {
            if (bytes ~ /^[0-9]+$/ && drops ~ /^[0-9]+$/ && backlog ~ /^[0-9]+$/ && now > 0)
                printf "%s %s %s %s\n", bytes, drops, backlog, now
            else
                exit 1
        }
    '
}

change_class() {
    local dev="$1" rate="$2" shaper="$3" burst_base_rate="$4"

    mw_realtime_curve "$rate" "$shaper" "$burst_base_rate"
    tc class change dev "$dev" parent 1:1 classid 1:11 hfsc rt \
        m1 "${MW_RT_BURST_RATE}kbit" d "${MW_RT_BURST_DURATION}ms" m2 "${MW_RT_SCHEDULER_RATE}kbit"
}

apply_rate() {
    local dev="$1" rate="$2" shaper="$3" burst_base_rate="$4" rv

    mw_lock_acquire "$LOCK_DIR" || return 2
    change_class "$dev" "$rate" "$shaper" "$burst_base_rate"
    rv=$?
    mw_lock_release_for "$LOCK_DIR" "$MW_LOCK_TOKEN"
    return "$rv"
}

write_status() {
    local state_dir="$1" direction="$2" dev="$3" current="$4" shaper="$5"
    local state="$6" peak="$7" desired="$8" backlog="$9" drop_delta="${10}"
    local priority_mode=adaptive scheduler_rate="$current"
    printf 'mode=adaptive priority=%s direction=%s device=%s scheduler_rate=%s recommended_rate=%s queue_budget_rate=%s floor=%s start=%s ceiling=%s peak=%s desired=%s backlog=%s drop_delta=%s state=%s\n' \
        "$priority_mode" "$direction" "$dev" "$scheduler_rate" "$current" "$MW_RT_START" \
        "$MW_RT_FLOOR" "$MW_RT_START" "$MW_RT_CEILING" "$peak" "$desired" "$backlog" "$drop_delta" "$state" \
        > "$state_dir/status"
}

reset_sample_state() {
    local state_dir="$1" bytes="$2" drops="$3" now="$4" current="$5"

    printf '%s\n' "$bytes" > "$state_dir/bytes"
    printf '%s\n' "$drops" > "$state_dir/drops"
    printf '%s\n' "$now" > "$state_dir/sample_ms"
    printf '%s\n' "$now" > "$state_dir/window_ms"
    printf '0\n' > "$state_dir/peak"
    printf '%s\n' "$current" > "$state_dir/desired"
    printf '0\n' > "$state_dir/backlog_samples"
}

process_direction() {
    local dev="$1" line_rate="$2" shaper="$3" direction="$4"
    local key state_dir current saved_current rate_needs_write stats bytes drops backlog now previous_bytes previous_drops previous_ms elapsed
    local delta_bytes delta_drops sample_rate window_ms peak rolling_peak desired window_complete
    local backlog_samples lower_target lower_since last_decrease last_increase new state rv

    [ -d "/sys/class/net/$dev" ] || return 0
    key="${dev}-${direction}"
    case "$key" in
        *[!A-Za-z0-9_.:@-]*) log "ERROR: unsafe adaptive state key for device '$dev'"; return 0 ;;
    esac
    state_dir="$STATE_ROOT/$key"
    [ -d "$state_dir" ] || mkdir -p "$state_dir"

    mw_realtime_adaptive_range "$line_rate"
    rate_needs_write=0
    if [ -r "$state_dir/rate" ]; then
        IFS= read -r saved_current < "$state_dir/rate"
        case "$saved_current" in
            ''|*[!0-9]*) current="$MW_RT_START"; rate_needs_write=1 ;;
            *) current="$saved_current" ;;
        esac
    else
        current="$MW_RT_START"
        rate_needs_write=1
    fi
    if [ "$current" -lt "$MW_RT_FLOOR" ]; then
        current="$MW_RT_FLOOR"
        rate_needs_write=1
    elif [ "$current" -gt "$MW_RT_CEILING" ]; then
        current="$MW_RT_CEILING"
        rate_needs_write=1
    fi
    [ "$rate_needs_write" -eq 0 ] || printf '%s\n' "$current" > "$state_dir/rate"

    stats="$(read_realtime_stats "$dev")" || return 0
    set -- $stats
    bytes="$1"; drops="$2"; backlog="$3"; now="$4"

    previous_bytes="$(read_number "$state_dir/bytes" 0)"
    previous_drops="$(read_number "$state_dir/drops" 0)"
    previous_ms="$(read_number "$state_dir/sample_ms" 0)"
    if [ "$previous_ms" -eq 0 ] || [ "$bytes" -lt "$previous_bytes" ] || [ "$drops" -lt "$previous_drops" ]; then
        reset_sample_state "$state_dir" "$bytes" "$drops" "$now" "$current"
        write_status "$state_dir" "$direction" "$dev" "$current" "$shaper" initializing 0 "$current" "$backlog" 0
        return 0
    fi

    elapsed=$((now - previous_ms))
    [ "$elapsed" -gt 0 ] || return 0
    delta_bytes=$((bytes - previous_bytes))
    delta_drops=$((drops - previous_drops))
    sample_rate=$((delta_bytes * 8 / elapsed))
    printf '%s\n' "$bytes" > "$state_dir/bytes"
    printf '%s\n' "$drops" > "$state_dir/drops"
    printf '%s\n' "$now" > "$state_dir/sample_ms"

    window_ms="$(read_number "$state_dir/window_ms" "$now")"
    peak="$(read_number "$state_dir/peak" 0)"
    rolling_peak="$(read_number "$state_dir/rolling_peak" 0)"
    desired="$(read_number "$state_dir/desired" "$current")"
    window_complete=0
    if [ $((now - window_ms)) -ge 1000 ]; then
        [ "$sample_rate" -gt "$peak" ] && peak="$sample_rate"
        rolling_peak="$peak"
        desired=$(((rolling_peak * 100 + 74) / 75))
        desired=$(((desired + 49) / 50 * 50))
        [ "$desired" -lt "$MW_RT_FLOOR" ] && desired="$MW_RT_FLOOR"
        [ "$desired" -gt "$MW_RT_CEILING" ] && desired="$MW_RT_CEILING"
        peak=0
        window_ms="$now"
        window_complete=1
    elif [ "$sample_rate" -gt "$peak" ]; then
        peak="$sample_rate"
    fi
    printf '%s\n' "$window_ms" > "$state_dir/window_ms"
    printf '%s\n' "$peak" > "$state_dir/peak"
    printf '%s\n' "$rolling_peak" > "$state_dir/rolling_peak"
    printf '%s\n' "$desired" > "$state_dir/desired"

    backlog_samples="$(read_number "$state_dir/backlog_samples" 0)"
    if [ "$backlog" -gt 0 ]; then
        backlog_samples=$((backlog_samples + 1))
    else
        backlog_samples=0
    fi
    printf '%s\n' "$backlog_samples" > "$state_dir/backlog_samples"

    lower_target="$(read_number "$state_dir/lower_target" "$current")"
    lower_since="$(read_number "$state_dir/lower_since" 0)"
    last_decrease="$(read_number "$state_dir/last_decrease" 0)"
    last_increase="$(read_number "$state_dir/last_increase" 0)"
    new="$current"
    state=tracking

    if [ "$delta_drops" -gt 0 ]; then
        new=$((current + 250))
        [ "$desired" -gt "$new" ] && new="$desired"
        [ "$new" -gt "$MW_RT_CEILING" ] && new="$MW_RT_CEILING"
        lower_since=0
        last_increase="$now"
        state=drop-increase
    elif [ "$backlog_samples" -ge 1 ] && [ $((now - last_increase)) -ge 1000 ]; then
        new=$((current + 100))
        [ "$desired" -gt "$new" ] && new="$desired"
        [ "$new" -gt "$MW_RT_CEILING" ] && new="$MW_RT_CEILING"
        lower_since=0
        last_increase="$now"
        state=backlog-increase
    elif [ "$window_complete" -eq 1 ] && [ "$desired" -ge $((current + 100)) ]; then
        new="$desired"
        lower_since=0
        last_increase="$now"
        state=demand-increase
    elif [ "$window_complete" -eq 1 ] && [ "$backlog" -eq 0 ] && [ "$desired" -lt "$current" ]; then
        if [ "$lower_target" -ne "$desired" ] || [ "$lower_since" -eq 0 ]; then
            lower_target="$desired"
            lower_since="$now"
        elif [ $((now - lower_since)) -ge 30000 ] && [ $((now - last_decrease)) -ge 10000 ]; then
            new=$((current - 100))
            [ "$new" -lt "$desired" ] && new="$desired"
            [ "$new" -lt "$MW_RT_FLOOR" ] && new="$MW_RT_FLOOR"
            last_decrease="$now"
            state=demand-decrease
        fi
    elif [ "$backlog" -gt 0 ] || [ "$desired" -ge "$current" ]; then
        lower_since=0
        lower_target="$current"
    fi

    printf '%s\n' "$lower_target" > "$state_dir/lower_target"
    printf '%s\n' "$lower_since" > "$state_dir/lower_since"
    printf '%s\n' "$last_decrease" > "$state_dir/last_decrease"
    printf '%s\n' "$last_increase" > "$state_dir/last_increase"

    if [ "$new" -ne "$current" ]; then
        apply_rate "$dev" "$new" "$shaper" "$MW_RT_START"
        rv=$?
        if [ "$rv" -eq 2 ]; then
            state=lock-busy
            new="$current"
        elif [ "$rv" -ne 0 ]; then
            printf '%s\n' "failed to change $dev from ${current}kbit to ${new}kbit" > "$state_dir/error"
            log "ERROR: adaptive $direction class update failed on $dev; preserving ${current}kbit and the existing leaf qdisc"
            state=degraded
            new="$current"
        else
            printf '%s\n' "$new" > "$state_dir/rate"
            rm -f "$state_dir/error"
            log "Adjusted $direction realtime HFSC rate on $dev: ${current}kbit -> ${new}kbit"
        fi
    fi

    write_status "$state_dir" "$direction" "$dev" "$new" "$shaper" "$state" "$rolling_peak" "$desired" "$backlog" "$delta_drops"
}

process_interface() {
    local section="$1" enabled device qdisc upload download shaper ifb

    config_get_bool enabled "$section" enabled 1
    [ "$enabled" -eq 1 ] || return 0
    config_get device "$section" device
    config_get qdisc "$section" qdisc hfsc
    case "$qdisc" in hfsc|hybrid) ;; *) return 0 ;; esac
    config_get upload "$section" upload
    config_get download "$section" download

    shaper="$upload"; [ "$qdisc" = hybrid ] && shaper=$((upload * 98 / 100))
    process_direction "$device" "$upload" "$shaper" wan

    ifb="ifb-$device"
    shaper="$download"; [ "$qdisc" = hybrid ] && shaper=$((download * 98 / 100))
    process_direction "$ifb" "$download" "$shaper" lan
}

mkdir -p "$STATE_ROOT"
while [ -f "$RESTARTING" ]; do sleep 1; done

config_load multiwan-qos
config_get RATE_MODE hfsc realtime_rate_mode auto
[ "$RATE_MODE" = adaptive ] || exit 0

while true; do
    [ -f "$RESTARTING" ] && exit 0
    config_foreach process_interface interface
    sleep "$SAMPLE_INTERVAL"
done

exit 0
