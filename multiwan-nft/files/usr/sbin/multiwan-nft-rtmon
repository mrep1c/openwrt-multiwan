#!/bin/sh

MULTIWAN_NFT_LIB_ROOT="${MULTIWAN_NFT_LIB_ROOT:-/lib}"
. "$MULTIWAN_NFT_LIB_ROOT/functions.sh"
. "$MULTIWAN_NFT_LIB_ROOT/functions/network.sh"
. "$MULTIWAN_NFT_LIB_ROOT/multiwan-nft/multiwan_nft.sh"
. "$MULTIWAN_NFT_LIB_ROOT/multiwan-nft/process-lock.sh"

RTMON_PID=""
RTMON_START=""
RTMON_SELF_START=""
RTMON_WORK_DIR=""
RTMON_OWNER_TOKEN=""
RTMON_FIFO=""
RTMON_ERROR_FILE=""
RTMON_INIT_LOCK=""
RTMON_CLEANED=0

# Explicit callback context for OpenWrt's config_foreach. BusyBox ash makes
# functions declared inside another function global, so keep callbacks at file
# scope and give their shared state package-specific names.
MULTIWAN_NFT_RTMON_IP=""
MULTIWAN_NFT_RTMON_FAMILY=""
MULTIWAN_NFT_RTMON_TID=0
MULTIWAN_NFT_RTMON_ACTIVE_TABLES=" "
MULTIWAN_NFT_RTMON_ROUTE_ACTION=""
MULTIWAN_NFT_RTMON_ROUTE_LINE=""

multiwan_nft_rtmon_child_stop()
{
	local count=0

	if mw_process_identity_alive "$RTMON_PID" "$RTMON_START"; then
		kill "$RTMON_PID" 2>/dev/null
		while mw_process_identity_alive "$RTMON_PID" "$RTMON_START" && [ "$count" -lt 2 ]; do
			sleep 1
			count=$((count + 1))
		done
		if mw_process_identity_alive "$RTMON_PID" "$RTMON_START"; then
			LOG warn "Force killing route monitor child $RTMON_PID"
			kill -KILL "$RTMON_PID" 2>/dev/null
		fi
	fi
	[ -n "$RTMON_PID" ] && wait "$RTMON_PID" 2>/dev/null
	RTMON_PID=""
	RTMON_START=""
}

multiwan_nft_rtmon_cleanup()
{
	[ "$RTMON_CLEANED" -eq 0 ] || return 0
	RTMON_CLEANED=1
	trap - EXIT HUP INT TERM
	multiwan_nft_rtmon_child_stop
	exec 3>&- 2>/dev/null
	exec 3<&- 2>/dev/null
	rm -f "$RTMON_INIT_LOCK"
	if [ -n "$RTMON_WORK_DIR" ] &&
		mw_lock_read_owner "$RTMON_WORK_DIR" &&
		[ "$MW_LOCK_OWNER_PID" = "$$" ] &&
		[ "$MW_LOCK_OWNER_START" = "$RTMON_SELF_START" ] &&
		[ "$MW_LOCK_OWNER_TOKEN" = "$RTMON_OWNER_TOKEN" ]; then
		rm -f "$RTMON_FIFO" "$RTMON_ERROR_FILE" \
			"$RTMON_WORK_DIR/owner" "$RTMON_WORK_DIR"/.owner.* 2>/dev/null
		rmdir "$RTMON_WORK_DIR" 2>/dev/null
	fi
}

multiwan_nft_rtmon_signal()
{
	exit 0
}

multiwan_nft_rtmon_remove_orphans()
{
	local family_flag="$1" pid_dir pid ppid start cmdline count

	for pid_dir in /proc/[0-9]*; do
		[ -r "$pid_dir/cmdline" ] || continue
		pid="${pid_dir##*/}"
		ppid="$(sed -n 's/^PPid:[[:space:]]*//p' "$pid_dir/status" 2>/dev/null)"
		[ "$ppid" = "1" ] || continue
		start="$(mw_process_start_time "$pid" 2>/dev/null)"
		cmdline="$(tr '\0' ' ' 2>/dev/null < "$pid_dir/cmdline")"
		case "$cmdline" in
			"ip -$family_flag monitor route"|"ip -$family_flag monitor route "|\
			"/sbin/ip -$family_flag monitor route"|"/sbin/ip -$family_flag monitor route "|\
			"/usr/sbin/ip -$family_flag monitor route"|"/usr/sbin/ip -$family_flag monitor route ")
				mw_process_identity_alive "$pid" "$start" || continue
				LOG warn "Stopping orphaned IPv$family_flag route monitor process $pid"
				kill "$pid" 2>/dev/null
				count=0
				while mw_process_identity_alive "$pid" "$start" && [ "$count" -lt 2 ]; do
					sleep 1
					count=$((count + 1))
				done
				mw_process_identity_alive "$pid" "$start" && kill -KILL "$pid" 2>/dev/null
				;;
		esac
	done
}

multiwan_nft_rtmon_remove_stale_workdirs()
{
	local family="$1" work_dir

	for work_dir in /tmp/multiwan-nft-rtmon-"$family".*; do
		[ -d "$work_dir" ] && [ ! -L "$work_dir" ] || continue
		mw_lock_read_owner "$work_dir" || continue
		mw_process_identity_alive "$MW_LOCK_OWNER_PID" "$MW_LOCK_OWNER_START" && continue

		LOG warn "Removing stale $family route monitor workspace $work_dir"
		rm -f "$work_dir/events" "$work_dir/error" \
			"$work_dir/owner" "$work_dir"/.owner.* 2>/dev/null
		rmdir "$work_dir" 2>/dev/null
	done
}

multiwan_nft_rtmon_create_workdir()
{
	local family="$1"

	RTMON_SELF_START="$(mw_process_start_time "$$")" || return 1
	RTMON_WORK_DIR="$(mktemp -d "/tmp/multiwan-nft-rtmon-${family}.XXXXXX")" || return 1
	RTMON_OWNER_TOKEN="rtmon:$$:$RTMON_SELF_START:${RTMON_WORK_DIR##*.}"
	if ! mw_lock_write_owner "$RTMON_WORK_DIR" "$$" \
		"$RTMON_SELF_START" "$RTMON_OWNER_TOKEN"; then
		rmdir "$RTMON_WORK_DIR" 2>/dev/null
		RTMON_WORK_DIR=""
		return 1
	fi
	RTMON_FIFO="$RTMON_WORK_DIR/events"
	RTMON_ERROR_FILE="$RTMON_WORK_DIR/error"
}

multiwan_nft_rtmon_collect_active_table()
{
	local iface="$1" family

	MULTIWAN_NFT_RTMON_TID=$((MULTIWAN_NFT_RTMON_TID + 1))
	config_get family "$iface" family ipv4
	[ "$family" = "$MULTIWAN_NFT_RTMON_FAMILY" ] || return
	if $NFT list chain $NFT_FAMILY $NFT_TABLE "multiwan_nft_iface_in_$iface" >/dev/null 2>&1; then
		MULTIWAN_NFT_RTMON_ACTIVE_TABLES="${MULTIWAN_NFT_RTMON_ACTIVE_TABLES}${MULTIWAN_NFT_RTMON_TID} "
	fi
}

multiwan_nft_rtmon_add_route_to_active_table()
{
	MULTIWAN_NFT_RTMON_TID=$((MULTIWAN_NFT_RTMON_TID + 1))
	[ -z "${MULTIWAN_NFT_RTMON_ACTIVE_TABLES##* $MULTIWAN_NFT_RTMON_TID *}" ] || return
	multiwan_nft_route_replace_idempotent "$MULTIWAN_NFT_RTMON_IP" \
		"$MULTIWAN_NFT_RTMON_TID" "$MULTIWAN_NFT_RTMON_ROUTE_LINE"
}

multiwan_nft_add_all_routes()
{
	local route_line ipv="$1"

	multiwan_nft_update_dev_to_table
	[ "$ipv" = "ipv6" ] && [ "$NO_IPV6" -ne 0 ] && return
	if [ "$ipv" = "ipv4" ]; then
		MULTIWAN_NFT_RTMON_IP="$IP4"
	elif [ "$ipv" = "ipv6" ]; then
		MULTIWAN_NFT_RTMON_IP="$IP6"
	fi
	MULTIWAN_NFT_RTMON_FAMILY="$ipv"
	MULTIWAN_NFT_RTMON_TID=0
	MULTIWAN_NFT_RTMON_ACTIVE_TABLES=" "
	config_foreach multiwan_nft_rtmon_collect_active_table interface
	[ "$MULTIWAN_NFT_RTMON_ACTIVE_TABLES" = " " ] && return
	multiwan_nft_get_routes | while read -r route_line; do
		MULTIWAN_NFT_RTMON_TID=""
		MULTIWAN_NFT_RTMON_ROUTE_LINE="$route_line"
		multiwan_nft_route_line_dev "MULTIWAN_NFT_RTMON_TID" "$route_line" "$ipv"
		if [ -n "$MULTIWAN_NFT_RTMON_TID" ] &&
			[ -z "${MULTIWAN_NFT_RTMON_ACTIVE_TABLES##* $MULTIWAN_NFT_RTMON_TID *}" ]; then
			multiwan_nft_route_replace_idempotent "$MULTIWAN_NFT_RTMON_IP" \
				"$MULTIWAN_NFT_RTMON_TID" "$route_line"
		elif [ -n "${route_line##default*}" ] && [ -n "${route_line##fe80::/64*}" ]; then
			MULTIWAN_NFT_RTMON_TID=0
			config_foreach multiwan_nft_rtmon_add_route_to_active_table interface
		fi
	done
}

multiwan_nft_rtmon_apply_route()
{
	local iface="$1" device error

	if [ -n "$iface" ] && [ "$(multiwan_nft_get_track_status "$iface")" != "active" ]; then
		LOG debug "interface $iface is disabled - skipping '$MULTIWAN_NFT_RTMON_ROUTE_LINE'"
		return
	fi

	# A delete notification may arrive after another path already flushed the
	# table. Check exact lines without storing the whole route table in ash.
	if [ "$MULTIWAN_NFT_RTMON_ROUTE_ACTION" = "del" ] &&
		! $MULTIWAN_NFT_RTMON_IP route list table "$MULTIWAN_NFT_RTMON_TID" 2>/dev/null |
			grep -Fxq "$MULTIWAN_NFT_RTMON_ROUTE_LINE"; then
		LOG debug "skipping already deleted route table $MULTIWAN_NFT_RTMON_TID - skipping '$MULTIWAN_NFT_RTMON_ROUTE_LINE'"
		return
	fi

	device=""
	[ -z "$iface" ] || network_get_device device "$iface"
	LOG debug "adjusting route $device: '$MULTIWAN_NFT_RTMON_IP route $MULTIWAN_NFT_RTMON_ROUTE_ACTION table $MULTIWAN_NFT_RTMON_TID $MULTIWAN_NFT_RTMON_ROUTE_LINE'"
	if [ "$MULTIWAN_NFT_RTMON_ROUTE_ACTION" = "replace" ]; then
		multiwan_nft_route_replace_idempotent "$MULTIWAN_NFT_RTMON_IP" \
			"$MULTIWAN_NFT_RTMON_TID" "$MULTIWAN_NFT_RTMON_ROUTE_LINE"
	else
		# shellcheck disable=SC2086
		error=$($MULTIWAN_NFT_RTMON_IP route "$MULTIWAN_NFT_RTMON_ROUTE_ACTION" \
			table "$MULTIWAN_NFT_RTMON_TID" $MULTIWAN_NFT_RTMON_ROUTE_LINE 2>&1) ||
			LOG warn "failed: '$MULTIWAN_NFT_RTMON_IP route $MULTIWAN_NFT_RTMON_ROUTE_ACTION table $MULTIWAN_NFT_RTMON_TID $MULTIWAN_NFT_RTMON_ROUTE_LINE' - error: $error"
	fi
}

multiwan_nft_rtmon_apply_route_for_interface()
{
	local iface="$1" family

	MULTIWAN_NFT_RTMON_TID=$((MULTIWAN_NFT_RTMON_TID + 1))
	config_get family "$iface" family ipv4
	[ "$family" = "$MULTIWAN_NFT_RTMON_FAMILY" ] || return
	multiwan_nft_rtmon_apply_route "$iface"
}

multiwan_nft_rtmon_resolve_route_table()
{
	MULTIWAN_NFT_RTMON_TID=""
	multiwan_nft_route_line_dev "MULTIWAN_NFT_RTMON_TID" \
		"$MULTIWAN_NFT_RTMON_ROUTE_LINE" "$MULTIWAN_NFT_RTMON_FAMILY"
	[ -z "$MULTIWAN_NFT_RTMON_TID" ] || return 0

	# The monitor's device map is initialized at startup. Rebuild it only when a
	# route names a device the cache does not know, such as after a PPP reconnect.
	# Device-less routes never benefit from an ubus/config refresh.
	case "$MULTIWAN_NFT_RTMON_ROUTE_LINE" in
		*" dev "*|dev\ *) ;;
		*) return 0 ;;
	esac
	multiwan_nft_update_dev_to_table
	multiwan_nft_route_line_dev "MULTIWAN_NFT_RTMON_TID" \
		"$MULTIWAN_NFT_RTMON_ROUTE_LINE" "$MULTIWAN_NFT_RTMON_FAMILY"
}

multiwan_nft_rtmon_route_handle()
{
	local event_line="$1"

	MULTIWAN_NFT_RTMON_ROUTE_LINE=${event_line##"Deleted "}
	MULTIWAN_NFT_RTMON_FAMILY=$2

	if [ "$MULTIWAN_NFT_RTMON_ROUTE_LINE" = "$event_line" ]; then
		MULTIWAN_NFT_RTMON_ROUTE_ACTION="replace"
		multiwan_nft_nft_add_set_element "multiwan_nft_connected_${MULTIWAN_NFT_RTMON_FAMILY}" \
			"${MULTIWAN_NFT_RTMON_ROUTE_LINE%% *}"
	else
		MULTIWAN_NFT_RTMON_ROUTE_ACTION="del"
		multiwan_nft_set_connected_${MULTIWAN_NFT_RTMON_FAMILY}
	fi

	if [ -z "${MULTIWAN_NFT_RTMON_ROUTE_LINE##*linkdown*}" ]; then
		LOG debug "attempting to add link on down interface - $MULTIWAN_NFT_RTMON_ROUTE_LINE"
	fi

	if [ "$MULTIWAN_NFT_RTMON_FAMILY" = "ipv4" ]; then
		MULTIWAN_NFT_RTMON_IP="$IP4"
	elif [ "$MULTIWAN_NFT_RTMON_FAMILY" = "ipv6" ] && [ "$NO_IPV6" -eq 0 ]; then
		MULTIWAN_NFT_RTMON_IP="$IP6"
	else
		LOG warn "route update called with invalid family - $MULTIWAN_NFT_RTMON_FAMILY"
		return
	fi
	MULTIWAN_NFT_RTMON_ROUTE_LINE="$(printf '%s\n' "$MULTIWAN_NFT_RTMON_ROUTE_LINE" |
		sed -ne "$MULTIWAN_NFT_ROUTE_LINE_EXP")"

	multiwan_nft_rtmon_resolve_route_table

	if [ -n "$MULTIWAN_NFT_RTMON_TID" ]; then
		multiwan_nft_rtmon_apply_route ""
	elif [ -n "${MULTIWAN_NFT_RTMON_ROUTE_LINE##default*}" ] &&
		[ -n "${MULTIWAN_NFT_RTMON_ROUTE_LINE##fe80::/64*}" ]; then
		MULTIWAN_NFT_RTMON_TID=0
		config_foreach multiwan_nft_rtmon_apply_route_for_interface interface
	fi
}

main()
{
	local IP family family_flag line child_status error_line

	multiwan_nft_init

	family=$1
	[ -z "$family" ] && family=ipv4
	if [ "$family" = "ipv6" ]; then
		if [ "$NO_IPV6" -ne 0 ]; then
			LOG warn "multiwan-nft-rtmon started for ipv6, but ipv6 not enabled on system"
			exit 1
		fi
		IP="$IP6"
		family_flag=6
	else
		IP="$IP4"
		family_flag=4
	fi

	RTMON_INIT_LOCK="/tmp/multiwan-nft-rtmon_init_${family}"
	trap multiwan_nft_rtmon_cleanup EXIT
	trap multiwan_nft_rtmon_signal HUP INT TERM

	multiwan_nft_rtmon_remove_orphans "$family_flag"
	multiwan_nft_rtmon_remove_stale_workdirs "$family"

	# Use a lock file to synchronize route population
	touch "$RTMON_INIT_LOCK"

	# Populate initial routes
	# Note: multiwan_nft_set_connected_* called from init script to avoid race conditions
	multiwan_nft_add_all_routes "$family"

	# Remove lock file to signal we're ready
	rm -f "$RTMON_INIT_LOCK"

	umask 077
	multiwan_nft_rtmon_create_workdir "$family" || {
		LOG error "Unable to create private IPv$family_flag route monitor workspace"
		return 1
	}
	mkfifo "$RTMON_FIFO" || {
		LOG error "Unable to create route monitor FIFO $RTMON_FIFO"
		return 1
	}

	# Keeping one read/write descriptor open prevents FIFO EOF spin. Integer
	# timed reads let the parent notice a dead monitor without relying on
	# fractional timeout behavior.
	exec 3<> "$RTMON_FIFO" || {
		LOG error "Unable to open route monitor FIFO $RTMON_FIFO"
		return 1
	}
	$IP monitor route > "$RTMON_FIFO" 2> "$RTMON_ERROR_FILE" &
	RTMON_PID=$!
	RTMON_START="$(mw_process_start_time "$RTMON_PID")"
	if [ -z "$RTMON_START" ]; then
		sleep 1
		RTMON_START="$(mw_process_start_time "$RTMON_PID")"
	fi
	[ -n "$RTMON_START" ] || {
		LOG error "Unable to identify route monitor child $RTMON_PID"
		return 1
	}

	while :; do
		line=""
		if ! IFS= read -r -t 5 line <&3; then
			if mw_process_identity_alive "$RTMON_PID" "$RTMON_START"; then
				continue
			fi
			wait "$RTMON_PID" 2>/dev/null
			child_status=$?
			LOG error "IPv$family_flag route monitor exited unexpectedly with status $child_status"
			if [ -s "$RTMON_ERROR_FILE" ]; then
				while IFS= read -r error_line; do
					[ -n "$error_line" ] && LOG error "ip monitor: $error_line"
				done < "$RTMON_ERROR_FILE"
			fi
			return 1
		fi
		[ -n "$line" ] || continue
		[ -z "${line##*table*}" ] && continue
		LOG debug "handling route update $family '$line'"
		multiwan_nft_rtmon_route_handle "$line" "$family"
	done
}
[ "${MULTIWAN_NFT_RTMON_LIBRARY_ONLY:-0}" = "1" ] || main "$@"
