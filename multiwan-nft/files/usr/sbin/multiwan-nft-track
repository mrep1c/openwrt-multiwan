#!/bin/sh

MULTIWAN_NFT_LIB_ROOT="${MULTIWAN_NFT_LIB_ROOT:-/lib}"
. "$MULTIWAN_NFT_LIB_ROOT/functions.sh"
. "$MULTIWAN_NFT_LIB_ROOT/functions/network.sh"
. "$MULTIWAN_NFT_LIB_ROOT/multiwan-nft/common.sh"
. "$MULTIWAN_NFT_LIB_ROOT/multiwan-nft/process-lock.sh"

INTERFACE=""
DEVICE=""

IFDOWN_EVENT=0
IFUP_EVENT=0
READY_RECHECK_INTERVAL=1
SLEEP_PID=""
SLEEP_START=""
TRACK_PID=""
TRACK_START=""
TRACKER_SELF_START=""
TRACKER_OWNER_FILE=""
TRACKER_OWNER_TOKEN=""
MULTIWAN_NFT_TRACK_IP_LIST=""
MULTIWAN_NFT_TRACK_IP_COUNT=0

stop_child() {
	local pid="$1" start="$2" label="$3" count=0

	if mw_process_identity_alive "$pid" "$start"; then
		kill "$pid" 2>/dev/null
		while mw_process_identity_alive "$pid" "$start" && [ "$count" -lt 2 ]; do
			sleep 1
			count=$((count + 1))
		done
		if mw_process_identity_alive "$pid" "$start"; then
			LOG warn "Force killing $label child $pid for interface $INTERFACE"
			kill -KILL "$pid" 2>/dev/null
		fi
	fi
	[ -n "$pid" ] && wait "$pid" 2>/dev/null || true
	return 0
}

stop_subprocs() {
	stop_child "$SLEEP_PID" "$SLEEP_START" "sleep"
	stop_child "$TRACK_PID" "$TRACK_START" "tracking probe"
	SLEEP_PID=""
	SLEEP_START=""
	TRACK_PID=""
	TRACK_START=""
}

WRAP() {
	# If libwrap exists, use it for proper fwmark binding
	if [ -f /lib/multiwan-nft/libwrap_mwan3_sockopt.so.1.0 ]; then
		# shellcheck disable=SC2048
		FAMILY=$FAMILY DEVICE=$DEVICE SRCIP=$SRC_IP FWMARK=$MMX_DEFAULT LD_PRELOAD=/lib/multiwan-nft/libwrap_mwan3_sockopt.so.1.0 "$@"
	else
		# Fallback: use native interface binding (#23: handle all track methods)
		local cmd="$1"
		shift
		case "$cmd" in
			*ping*)
				# Bind tracking probes to the real device. Binding only to
				# the source address can still let policy/default routing send
				# the probe through another WAN, which makes a healthy backup
				# interface look down when the preferred WAN is wedged.
				"$cmd" -I "$DEVICE" "$@"
				;;
			arping)
				# arping already uses -I, just run as-is
				"$cmd" "$@"
				;;
			httping)
				# httping supports -b for source address binding
				"$cmd" -b "$SRC_IP" "$@"
				;;
			nping)
				# nping supports -S for source IP and -e for device
				"$cmd" -S "$SRC_IP" -e "$DEVICE" "$@"
				;;
			*)
				# For other commands, just run without special binding
				"$cmd" "$@"
				;;
		esac
	fi
}

multiwan_nft_tracker_publish_owner() {
	local owner_tmp

	TRACKER_SELF_START="$(mw_process_start_time "$$")" || return 1
	TRACKER_OWNER_FILE="$MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/OWNER"
	TRACKER_OWNER_TOKEN="tracker:$INTERFACE:$$:$TRACKER_SELF_START"
	owner_tmp="$MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/.OWNER.$$"
	printf '%s %s %s\n' "$$" "$TRACKER_SELF_START" "$TRACKER_OWNER_TOKEN" > "$owner_tmp" || {
		rm -f "$owner_tmp"
		return 1
	}
	mv "$owner_tmp" "$TRACKER_OWNER_FILE" || {
		rm -f "$owner_tmp"
		return 1
	}
}

multiwan_nft_tracker_remove_owner() {
	local pid start token

	[ -n "$TRACKER_OWNER_FILE" ] && [ -r "$TRACKER_OWNER_FILE" ] || return 0
	pid=""
	start=""
	token=""
	read -r pid start token < "$TRACKER_OWNER_FILE" || return 0
	[ "$pid" = "$$" ] && [ "$start" = "$TRACKER_SELF_START" ] &&
		[ "$token" = "$TRACKER_OWNER_TOKEN" ] || return 0
	rm -f "$TRACKER_OWNER_FILE" "$MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/.OWNER.$$"
}

multiwan_nft_tracker_cleanup() {
	trap - EXIT HUP INT TERM
	LOG notice "Stopping multiwan-nft-track for interface \"${INTERFACE}\". Status was \"${STATUS}\""
	stop_subprocs
	multiwan_nft_tracker_remove_owner
}

multiwan_nft_tracker_signal() {
	exit 0
}

if_down() {
	LOG info "Detect ifdown event on interface ${INTERFACE} (${DEVICE})"
	IFDOWN_EVENT=1
	stop_subprocs
}

if_up() {
	LOG info "Detect ifup event on interface ${INTERFACE} (${DEVICE})"
	IFDOWN_EVENT=0
	IFUP_EVENT=1
	STARTED=1
	stop_subprocs
}

ping_test_host() {
	if [ "$FAMILY" = "ipv6" ]; then
		echo "::1"
	else
		echo "127.0.0.1"
	fi
}

get_ping_command() {
	if [ -x "/usr/bin/ping" ] && /usr/bin/ping -${FAMILY#ipv} -c1 -q "$(ping_test_host)" >/dev/null 2>&1; then
		# -4 option added in iputils c3e68ac6 so need to check if we can use it
		# or if we must use ping and ping6
		echo "/usr/bin/ping -${FAMILY#ipv}"
	elif [ "$FAMILY" = "ipv6" ] && [ -x "/usr/bin/ping6" ]; then
		echo "/usr/bin/ping6"
	elif [ "$FAMILY" = "ipv4" ] && [ -x "/usr/bin/ping" ]; then
		echo "/usr/bin/ping"
	elif [ -x "/bin/ping" ]; then
		echo "/bin/ping -${FAMILY#ipv}"
	else
		return 1
	fi
}

validate_track_method() {
	case "$1" in
		ping)
			PING=$(get_ping_command)
			if [ $? -ne 0 ]; then
				LOG warn "Missing ping. Please enable BUSYBOX_DEFAULT_PING and recompile busybox or install iputils-ping package."
				return 1
			fi
			;;
		arping)
			command -v arping 1>/dev/null 2>&1 || {
				LOG warn "Missing arping. Please install iputils-arping package."
				return 1
			}
			;;
		httping)
			command -v httping 1>/dev/null 2>&1 || {
				LOG warn "Missing httping. Please install httping package."
				return 1
			}
			;;
		nping-*)
			command -v nping 1>/dev/null 2>&1 || {
				LOG warn "Missing nping. Please install nping package."
				return 1
			}
			;;
		*)
			LOG warn "Unsupported tracking method: $track_method"
			return 2
			;;
	esac
}

validate_wrap() {
	# libwrap is optional - we have a fallback using native interface binding
	[ -f /lib/multiwan-nft/libwrap_mwan3_sockopt.so.1.0 ] && return
	LOG notice "libwrap_mwan3_sockopt not found, using native interface binding"
}

disconnected() {
	local status quiet reason

	status=""
	if [ -r "$MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/STATUS" ]; then
		{ IFS= read -r status < "$MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/STATUS" || [ -n "$status" ]; } 2>/dev/null || status=
	fi
	quiet="${1:-0}"
	reason="${2:-probe}"

	STATUS='offline'
	echo "offline" > $MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/STATUS
	echo "$reason" > $MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/OFFLINE_REASON
	get_uptime > $MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/OFFLINE
	echo "0" > $MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/ONLINE
	score=0
	[ "$quiet" = 1 ] && return

	# Only execute disconnectd action if status was online or disconnecting
	if [ "$status" = "online" ] || [ "$status" = "disconnecting" ]; then
		LOG notice "Interface $INTERFACE ($DEVICE) is offline"
		env -i ACTION="disconnected" INTERFACE="$INTERFACE" DEVICE="$DEVICE" OFFLINE_REASON="$reason" /sbin/hotplug-call iface
	else
		LOG notice "Skip disconnected event for $INTERFACE ($DEVICE)"
	fi
}

connected() {
	STATUS='online'
	echo "online" > $MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/STATUS
	echo "none" > $MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/OFFLINE_REASON
	echo "0" > $MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/OFFLINE
	get_uptime > $MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/ONLINE
	score=$((down+up))
	host_up_count=0
	lost=0
	turn=0
	loss=0
	LOG notice "Interface $INTERFACE ($DEVICE) is online"
	env -i FIRSTCONNECT=$1 ACTION="connected" INTERFACE="$INTERFACE" DEVICE="$DEVICE" /sbin/hotplug-call iface
}

disconnecting() {
	if [ "$STATUS" != "disconnecting" ] ; then
		STATUS="disconnecting"
		echo "disconnecting" > $MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/STATUS
		LOG notice "Interface $INTERFACE ($DEVICE) is disconnecting"
		env -i ACTION="disconnecting" INTERFACE="$INTERFACE" DEVICE="$DEVICE" /sbin/hotplug-call iface
	fi
}

connecting() {
	if [ "$STATUS" != "connecting" ] ; then
		STATUS="connecting"
		echo "connecting" > $MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/STATUS
		LOG notice "Interface $INTERFACE ($DEVICE) is connecting"
		env -i ACTION="connecting" INTERFACE="$INTERFACE" DEVICE="$DEVICE" /sbin/hotplug-call iface
	fi
}

waiting() {
	local true_iface="$1"

	if [ "$STATUS" != "waiting" ]; then
		LOG notice "Waiting for interface $INTERFACE ($true_iface) to become ready"
	fi

	STATUS='waiting'
	echo "waiting" > $MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/STATUS
	STARTED=0
}

firstconnect() {
	local true_iface
	network_flush_cache

	multiwan_nft_get_true_iface true_iface $INTERFACE
	DEVICE=""
	network_get_device DEVICE $true_iface

	if ! network_is_up "$true_iface" || [ -z "$DEVICE" ]; then
		waiting "$true_iface"
		return
	fi

	if [ "$STATUS" != "online" ]; then
		config_get STATUS $INTERFACE initial_state "online"
	fi

	multiwan_nft_get_src_ip SRC_IP $INTERFACE

	LOG debug "firstconnect: called on $INTERFACE/$true_iface ($DEVICE). Status is $STATUS. SRC_IP is $SRC_IP"

	STARTED=1
	if [ "$STATUS" = "offline" ]; then
		disconnected 1
	else
		connected 1
	fi
}

update_status() {
	local track_ip="$1"

	echo "$2" > "$MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/TRACK_${track_ip}"
	[ -z "$3" ] && return
	echo "$3" > "$MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/LATENCY_${track_ip}"
	echo "$4" > "$MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/LOSS_${track_ip}"
}

log_tracking_failure_context() {
	local target="$1" next_state="$2" current_score="$3" current_lost="$4"
	local IP route_default route_src route_oif route_marked

	multiwan_nft_debug_enabled || return 0
	[ -n "$target" ] || return 0
	[ "$FAMILY" = "ipv6" ] && IP="$IP6" || IP="$IP4"

	route_default="$($IP route get "$target" 2>&1)"
	route_src="$($IP route get "$target" from "$SRC_IP" 2>&1)"
	route_oif="$($IP route get "$target" oif "$DEVICE" 2>&1)"
	route_marked="$($IP route get "$target" from "$SRC_IP" mark "$MMX_DEFAULT" 2>&1)"

	LOG debug "tracking failure context: interface=$INTERFACE device=$DEVICE next_state=$next_state target=$target src=$SRC_IP score=$current_score lost=$current_lost reliability=$reliability mmx_default=$MMX_DEFAULT/$MMX_MASK route_default=[$route_default] route_src=[$route_src] route_oif=[$route_oif] route_marked=[$route_marked]"
}

multiwan_nft_tracker_collect_target() {
	MULTIWAN_NFT_TRACK_IP_LIST="${MULTIWAN_NFT_TRACK_IP_LIST}${MULTIWAN_NFT_TRACK_IP_LIST:+ }$1"
	MULTIWAN_NFT_TRACK_IP_COUNT=$((MULTIWAN_NFT_TRACK_IP_COUNT + 1))
}

main() {
	local reliability count timeout interval failure_interval
	local recovery_interval down up size
	local keep_failure_interval check_quality failure_latency
	local recovery_latency failure_loss recovery_loss

	local max_ttl httping_ssl track_ips do_log
	local target_count host_down_count round_state max_failures

	INTERFACE=$1
	STATUS=""
	STARTED=0
	TRACK_OUTPUT=$MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/TRACK_OUTPUT

	multiwan_nft_init || return 1

	mkdir -p "$MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE"

	trap multiwan_nft_tracker_cleanup EXIT
	trap multiwan_nft_tracker_signal HUP INT TERM
	trap if_down USR1
	trap if_up USR2
	multiwan_nft_tracker_publish_owner || {
		LOG error "Unable to publish tracker process identity for interface $INTERFACE"
		return 1
	}

	config_get FAMILY $INTERFACE family ipv4
	config_get track_method $INTERFACE track_method ping
	config_get_bool httping_ssl $INTERFACE httping_ssl 0
	validate_track_method $track_method || {
		track_method=ping
		if validate_track_method $track_method; then
			LOG warn "Using ping to track interface $INTERFACE availability"
		else
			LOG err "No track method available"
			exit 1
		fi
	}
	config_get reliability $INTERFACE reliability 1
	config_get count $INTERFACE count 1
	config_get timeout $INTERFACE timeout 4
	config_get interval $INTERFACE interval 10
	config_get down $INTERFACE down 5
	config_get up $INTERFACE up 5
	config_get size $INTERFACE size 56
	config_get max_ttl $INTERFACE max_ttl 60
	config_get failure_interval $INTERFACE failure_interval $interval
	config_get_bool keep_failure_interval $INTERFACE keep_failure_interval 0
	config_get recovery_interval $INTERFACE recovery_interval $interval
	config_get_bool check_quality $INTERFACE check_quality 0
	config_get failure_latency $INTERFACE failure_latency 1000
	config_get recovery_latency $INTERFACE recovery_latency 500
	config_get failure_loss $INTERFACE failure_loss 40
	config_get recovery_loss $INTERFACE recovery_loss 10
	local sleep_time result ping_status loss latency quality_sample
	MULTIWAN_NFT_TRACK_IP_LIST=""
	MULTIWAN_NFT_TRACK_IP_COUNT=0
	config_list_foreach "$1" track_ip multiwan_nft_tracker_collect_target
	track_ips="$MULTIWAN_NFT_TRACK_IP_LIST"
	target_count=$MULTIWAN_NFT_TRACK_IP_COUNT

	case "$reliability:$count:$timeout:$interval:$down:$up:$failure_interval:$recovery_interval:$failure_latency:$recovery_latency:$failure_loss:$recovery_loss" in
		*[!0-9:]*|:*|*::*)
			LOG err "Invalid non-numeric tracking configuration for interface $INTERFACE"
			exit 1
			;;
	esac
	if [ "$target_count" -lt 1 ] || [ "$reliability" -lt 1 ] || [ "$reliability" -gt "$target_count" ]; then
		LOG err "Invalid reliability $reliability for $target_count tracking target(s) on interface $INTERFACE"
		exit 1
	fi
	if [ "$count" -lt 1 ] || [ "$timeout" -lt 1 ] || [ "$interval" -lt 1 ] ||
		[ "$failure_interval" -lt 1 ] || [ "$recovery_interval" -lt 1 ] ||
		[ "$down" -lt 1 ] || [ "$up" -lt 1 ] ||
		[ "$failure_loss" -gt 100 ] || [ "$recovery_loss" -gt 100 ]; then
		LOG err "Tracking counts, intervals and transition rounds must be positive; loss thresholds must be 0-100 on $INTERFACE"
		exit 1
	fi
	if [ "$recovery_latency" -gt "$failure_latency" ] || [ "$recovery_loss" -gt "$failure_loss" ]; then
		LOG err "Recovery quality thresholds must not exceed failure thresholds on interface $INTERFACE"
		exit 1
	fi
	max_failures=$((target_count - reliability))

	local score=$((down+up))
	local host_up_count=0
	local host_down_count=0
	local lost=0
	local turn=0

	while true; do
		if [ "${IFDOWN_EVENT}" -eq 1 ]; then
			LOG debug "Register ifdown event on interface ${INTERFACE} (${DEVICE})"
			disconnected 0 ifdown
			waiting "$INTERFACE"
			IFDOWN_EVENT=0
		fi
		if [ "${IFUP_EVENT}" -eq 1 ]; then
			LOG debug "Register ifup event on interface ${INTERFACE} (${DEVICE})"
			firstconnect
			IFUP_EVENT=0
		fi

		if [ "$STARTED" -eq 0 ]; then
			firstconnect
			if [ "$STARTED" -eq 0 ]; then
				sleep "$READY_RECHECK_INTERVAL" &
				SLEEP_PID=$!
				SLEEP_START="$(mw_process_start_time "$SLEEP_PID")"
				wait "$SLEEP_PID"
			fi
			SLEEP_PID=""
			SLEEP_START=""
			continue
		fi
		sleep_time=$interval
		last_failed_target=
		round_state=neutral
		for track_ip in $track_ips; do
			if [ "$host_up_count" -lt "$reliability" ]; then
				result=1
				loss=
				latency=
				quality_sample=0
				case "$track_method" in
					ping)
						if [ "$check_quality" -eq 0 ]; then
							WRAP $PING -n -c $count -W $timeout -s $size -t $max_ttl -q $track_ip >/dev/null 2>&1 &
							TRACK_PID=$!
							TRACK_START="$(mw_process_start_time "$TRACK_PID")"
							wait "$TRACK_PID"
							result=$?
							TRACK_PID=""
							TRACK_START=""
						else
							quality_sample=1
							WRAP $PING -n -c $count -W $timeout -s $size -t $max_ttl -q $track_ip 2>/dev/null > $TRACK_OUTPUT &
							TRACK_PID=$!
							TRACK_START="$(mw_process_start_time "$TRACK_PID")"
							wait "$TRACK_PID"
							ping_status=$?
							TRACK_PID=""
							TRACK_START=""
							loss="$(sed $TRACK_OUTPUT -ne 's/.*\([0-9]\+\)% packet loss.*/\1/p')"
							if [ "$ping_status" -ne 0 ] || [ "$loss" -eq 100 ]; then
								latency=999999
								loss=100
							else
								latency="$(sed $TRACK_OUTPUT -ne 's%\(rtt\|round-trip\).* = [^/]*/\([0-9]\+\).*%\2%p')"
							fi
						fi
					;;
					arping)
						WRAP arping -I $DEVICE -c $count -w $timeout -q $track_ip >/dev/null 2>&1 &
						TRACK_PID=$!
						TRACK_START="$(mw_process_start_time "$TRACK_PID")"
						wait "$TRACK_PID"
						result=$?
						TRACK_PID=""
						TRACK_START=""
					;;
					httping)
						if [ "$httping_ssl" -eq 1 ]; then
							WRAP httping -c $count -t $timeout -q "https://$track_ip" >/dev/null 2>&1 &
						else
							WRAP httping -c $count -t $timeout -q "http://$track_ip" >/dev/null 2>&1 &
						fi
						TRACK_PID=$!
						TRACK_START="$(mw_process_start_time "$TRACK_PID")"
						wait "$TRACK_PID"
						result=$?
						TRACK_PID=""
						TRACK_START=""
					;;
					nping-*)
						WRAP nping -${FAMILY#ipv} -c $count $track_ip --${track_method#nping-} > $TRACK_OUTPUT &
						TRACK_PID=$!
						TRACK_START="$(mw_process_start_time "$TRACK_PID")"
						wait "$TRACK_PID"
						result=$(grep Lost $TRACK_OUTPUT | awk '{print $12}')
						TRACK_PID=""
						TRACK_START=""
					;;
				esac
				do_log=""
				if [ "$check_quality" -eq 0 ] || [ "$quality_sample" -eq 0 ]; then
					if [ "$result" -eq 0 ]; then
						host_up_count=$((host_up_count + 1))
						update_status "$track_ip" "up"

						[ "$score" -le "$up" ] && do_log="success"
					else
						lost=$((lost + 1))
						host_down_count=$((host_down_count + 1))
						last_failed_target="$track_ip"
						update_status "$track_ip" "down"

						[ "$score" -gt "$up" ] && do_log="failed"
					fi
					[ -n "$do_log" ] && LOG info "Check ($track_method) ${do_log} for target \"$track_ip\" on interface $INTERFACE ($DEVICE). Current score: $score"

				else
					case "$loss:$latency" in
						*[!0-9:]*|:*|*::*) loss=100; latency=999999 ;;
					esac
					if [ "$loss" -ge "$failure_loss" ] || [ "$latency" -ge "$failure_latency" ]; then
						lost=$((lost + 1))
						host_down_count=$((host_down_count + 1))
						last_failed_target="$track_ip"
						update_status "$track_ip" "down" $latency $loss

						[ "$score" -gt "$up" ] && do_log="failed"
					elif [ "$loss" -le "$recovery_loss" ] && [ "$latency" -le "$recovery_latency" ]; then
						host_up_count=$((host_up_count + 1))
						update_status "$track_ip" "up" $latency $loss

						[ "$score" -le "$up" ] && do_log="success"
					else
						update_status "$track_ip" "neutral" "$latency" "$loss"
					fi
					[ -n "$do_log" ] && LOG info "Check (${track_method}: latency=${latency}ms loss=${loss}%) ${do_log} for target \"$track_ip\" on interface $INTERFACE ($DEVICE). Current score: $score"
				fi
			else
				echo "skipped" > $MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/TRACK_${track_ip}
			fi
		done

		if [ "$host_up_count" -ge "$reliability" ]; then
			round_state=up
		elif [ "$host_down_count" -gt "$max_failures" ]; then
			round_state=down
		fi
		echo "$round_state" > $MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/LAST_PROBE_RESULT

		if [ "$round_state" = "down" ]; then
			score=$((score - 1))

			if [ "$score" -lt "$up" ]; then
				score=0
				[ ${keep_failure_interval} -eq 1 ] && sleep_time=$failure_interval
			elif [ "$score" -eq "$up" ]; then
				log_tracking_failure_context "$last_failed_target" "offline" "$score" "$lost"
				disconnecting
				sleep_time=$failure_interval
				disconnected 0 probe
			elif [ "$score" -gt "$up" ]; then
				log_tracking_failure_context "$last_failed_target" "disconnecting" "$score" "$lost"
				disconnecting
				sleep_time=$failure_interval
			fi
		elif [ "$round_state" = "up" ]; then
			if [ "$score" -lt $((down+up)) ] && [ "$lost" -gt 0 ]; then
				LOG info "Lost $((lost*count)) ping(s) on interface $INTERFACE ($DEVICE). Current score: $score"
			fi

			score=$((score + 1))
			lost=0

			if [ "$score" -lt "$up" ]; then
				connecting
				sleep_time=$recovery_interval
			elif [ "$score" -eq "$up" ]; then
				connecting
				sleep_time=$recovery_interval
				connected
			elif [ "$score" -gt "$up" ]; then
				echo "online" > $MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/STATUS
				score=$((down+up))
			fi
		else
			case "$STATUS" in
				offline|disconnecting|connecting) sleep_time=$failure_interval ;;
			esac
		fi

		turn=$((turn + 1))
		echo "${lost}" > $MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/LOST
		echo "${score}" > $MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/SCORE
		echo "${turn}" > $MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/TURN
		get_uptime > $MULTIWAN_NFT_TRACK_STATUS_DIR/$INTERFACE/TIME

		host_up_count=0
		host_down_count=0
		if [ "${IFDOWN_EVENT}" -eq 0 ] && [ "${IFUP_EVENT}" -eq 0 ]; then
			sleep "${sleep_time}" &
			SLEEP_PID=$!
			SLEEP_START="$(mw_process_start_time "$SLEEP_PID")"
			wait "$SLEEP_PID"
			SLEEP_PID=""
			SLEEP_START=""
		fi

	done
}

[ "${MULTIWAN_NFT_TRACK_LIBRARY_ONLY:-0}" = "1" ] || main "$@"
